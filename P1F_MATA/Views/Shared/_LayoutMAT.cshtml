@using P1F_MATA.Function
@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MATA</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">

    <!-- Bootstrap 4 (AdminLTE) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- AdminLTE -->
    <link href="~/lib/adminlte/dist/css/adminlte.css" rel="stylesheet" />

    <!-- DataTables -->
    <link rel="stylesheet" href="~/lib/datatables-2/datatables.css" />
    <link rel="stylesheet" href="~/lib/DataTables-1.10.22/css/dataTables.bootstrap4.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/columncontrol/1.1.1/css/columnControl.bootstrap5.min.css" />

    <!-- Plugins -->
    <link href="~/lib/adminlte/plugins/sweetalert2/sweetalert2.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/chart.js/Chart.min.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/overlayScrollbars/css/OverlayScrollbars.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/css/bootstrap-select.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-fonts.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="sidebar-mini layout-fixed" style="padding:0 !important; margin:0 !important;">

    <div class="wrapper">
        <!-- Sidebar -->
        <partial name="_Sidebar" />

        <!-- Content -->
        <div class="content-wrapper">
            @RenderBody()
        </div>

        <!-- Footer -->
        <partial name="_footer" />
    </div>

    <!-- jQuery (hanya sekali, lokal) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Bootstrap 4 -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- AdminLTE -->
    <script src="~/lib/adminlte/dist/js/adminlte.min.js"></script>
    <script src="~/lib/adminlte/plugins/overlayScrollbars/js/jquery.overlayScrollbars.min.js"></script>
    <script src="~/lib/adminlte/plugins/moment/moment.min.js"></script>
    <script src="~/lib/adminlte/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/lib/adminlte/plugins/sweetalert2/sweetalert2.min.js"></script>

    <!-- DataTables -->
    <script src="~/lib/DataTables-1.10.22/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/DataTables-1.10.22/js/dataTables.bootstrap4.min.js"></script>

    <!-- Select2 & Bootstrap Select -->
    <script src="~/lib/select2-4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/js/bootstrap-select.min.js"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

    <!-- Date Pickers -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            // Highlight active nav link
            var currentUrl = window.location.pathname;
            $('ul.nav-sidebar a').each(function () {
                if (currentUrl === $(this).attr('href')) {
                    $(this).addClass('active');
                    $(this).closest('.nav-treeview').css('display', 'block').prev().addClass('active');
                    $(this).closest('.nav-item.has-treeview').addClass('menu-open');
                }
            });

            // Sidebar logo toggle
            const $body   = $('body');
            const $sidebar = $('.main-sidebar');
            const $img    = $('#sidebar-brand-img');
            const imgOpen   = '@Url.Content("~/assets/logo.png")';
            const imgClosed = '@Url.Content("~/assets/logos.png")';

            function updateSidebarLogo() {
                const isCollapsed = $body.hasClass('sidebar-collapse') && !$body.hasClass('sidebar-open');
                $img.attr('src', isCollapsed ? imgClosed : imgOpen);
                $img.css(isCollapsed
                    ? { 'max-height': '25px', 'max-width': '40px' }
                    : { 'max-height': '35px', 'max-width': 'initial' });
            }

            updateSidebarLogo();

            $(document).on('click', '[data-widget="pushmenu"]', function (e) {
                e.preventDefault();
                setTimeout(updateSidebarLogo, 350);
            });

            $sidebar.on('mouseenter', function () {
                if ($body.hasClass('sidebar-collapse')) {
                    $img.attr('src', imgOpen).css({ 'max-height': '35px', 'max-width': 'initial' });
                }
            });

            $sidebar.on('mouseleave', function () {
                if ($body.hasClass('sidebar-collapse')) updateSidebarLogo();
            });
        });

        // Session expiration warning (15 menit)
        function showSessionExpirationModal() {
            Swal.fire({
                title: 'Session Expiration Notice',
                text: 'Your session is about to expire. Stay logged in or log out?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Stay Logged In',
                cancelButtonText: 'Log Out',
                reverseButtons: true,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("RefreshSession", "Login")',
                        method: 'POST',
                        success: () => location.reload(),
                        error:   () => console.log('Error refreshing session')
                    });
                } else {
                    window.location.href = '@Url.Action("Logout", "Home")';
                }
            });
        }
        setTimeout(showSessionExpirationModal, 15 * 60 * 1000);

        // Tutup sidebar saat klik body
        $('body').on('click', function () { $(this).removeClass('sidebar-open'); });

        // Logout confirmation
        $('#btn-logout').on('click', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Logout Confirmation',
                text: 'Are you sure you want to exit?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-sign-out-alt"></i> Yes, Logout',
                cancelButtonText: 'Cancelled',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed)
                    window.location.href = '@Url.Action("Logout", "Home")';
            });
        });

        function number_to_k(n, precision = 2) {
            return (n / 1000).toFixed(precision) + 'K';
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>

<style>
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

    .dot { height: 20px; width: 20px; border-radius: 50%; display: inline-block; }

    .nav-tabs .nav-link.active  { background-color: #007bff; color: white; border-color: #007bff #007bff #fff; }
    .nav-tabs .nav-link:hover   { background-color: #e9f5ff; color: #007bff; }

    .nav-sidebar .nav-link p,
    .nav-sidebar .nav-header    { font-size: 10pt !important; }

    /* Sidebar user card */
    .sidebar-user-card {
        background-color: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        position: fixed;
        bottom: 8px; left: 8px;
        width: calc(250px - 16px);
        z-index: 1050;
        transition: width 0.3s ease, background 0.2s;
        overflow: hidden;
    }
    .sidebar-user-card:hover { background-color: rgba(255,255,255,0.13); }

    .sidebar-collapse:not(.sidebar-open) .sidebar-user-card  { width: calc(4.6rem - 16px); }
    .sidebar-collapse:not(.sidebar-open) .sidebar-user-info,
    .sidebar-collapse:not(.sidebar-open) #btn-logout         { opacity:0; width:0; overflow:hidden; pointer-events:none; transition: opacity 0.2s ease, width 0.2s ease; }

    .sidebar-user-info, #btn-logout { opacity:1; transition: opacity 0.3s ease, width 0.3s ease; }

    .sidebar-open .sidebar-user-card    { width: calc(250px - 16px) !important; }
    .sidebar-open .sidebar-user-info,
    .sidebar-open #btn-logout           { opacity:1 !important; width:auto !important; pointer-events:auto !important; }

    .sidebar .nav-sidebar { padding-bottom: 70px; }
    #btn-logout:hover i   { color: #ff6b6b !important; transition: color 0.2s; }
</style>