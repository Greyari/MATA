@using P1F_MATA.Models
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_LayoutMAT.cshtml";
    var userLevel = User.FindFirst("P1F_MATA_level")?.Value;
    bool isAdmin = (userLevel == "admin");
    bool isAdminObservation = (userLevel == "admin_observation");
    var current_sesa = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "N/A";
    var current_name = User.FindFirst("P1F_MATA_name")?.Value ?? "N/A";
}

@* ===== CSS KHUSUS HALAMAN INI ===== *@
@section Styles {
    <style>
        label.actual-btnn {
            display: inline-block;
            background-color: #3dcd58;
            color: white;
            padding: 0.5rem;
            font-family: sans-serif;
            border-radius: 0.3rem;
            cursor: pointer;
            width: 100px;
            height: 30px;
            font-size: 12px;
            text-align: center;
        }

        .modal-dialog {
            max-width: 110% !important;
            height: 100%;
            padding: 0;
            margin: 0;
        }

        .modal {
            padding-right: 4px !important;
            padding: .5%;
        }

        .pdfFile-form {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
            line-height: 1.5;
            border-radius: 0.2rem;
        }

        .responsive {
            height: 400px;
        }

        table#table_detail tr > td {
            padding: 5px;
            background-color: #AFDDFF;
        }

        table#table_detail thead th {
            background-color: #428bca !important;
            color: white;
        }
    </style>
}

@* ===== KONTEN UTAMA (tanpa <div class="wrapper">) ===== *@

<!-- HERO HEADER -->
<partial name="_HeroHeader" model='("Machine Abnormality", "/images/background/bgmachineabnormality.jpeg")' />

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12 mt-3">
            <div class="card">
                <div class="card-body">
                    <div class="row mt-3">
                        <div class="col-lg-2 col-md-2 col-sm-6">
                            <label style="font-size:10pt; font-weight:bold;">Date From</label>
                            <input type="date" id="date_from" value="" class="form-control form-control-sm text-center" />
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-6">
                            <label style="font-size:10pt;font-weight:bold;">Date To</label>
                            <input type="date" id="date_to" value="" class="form-control form-control-sm text-center" />
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-6">
                            <div class="form-group">
                                <label style="font-size:10pt;font-weight:bold;">Facility</label>
                                <select class="form-select form-select-sm select2" id="filter_facility" style="width:100%;">
                                    <option value="ALL">ALL</option>
                                    @foreach (var facility in ViewBag.Facility)
                                    {
                                        <option value="@facility.Code">@facility.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6 align-self-end">
                            <div class="form-group">
                                <button class="btn btn-info btn-sm btn-block" onclick="addData()">
                                    <i class="fa fa-plus mr-1"></i> Add Abnormality
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped border fixed" id="tbl_details_filter" style="font-size:10pt;">
                            <thead class="bg-success" style="position: sticky; top:0">
                                <tr class="text-center sticky-header">
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 6%;">Order ID</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 6%;">Date</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 10%;">Facility</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 8%;">Line/Cell no</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 9%;">Station ID</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 9%;">TPM Tag</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 10%;">Operator Sesa</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 15%;">Findings</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 8%;">Picture</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 6%;">Attachment</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 5%;">Status</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 10%;">Action Owner</th>
                                    <th class="font-calibri border-right align-middle text-center text-white" style="width: 10%;">Validator</th>
                                    <th class="font-calibri align-middle text-center text-white" style="width: 10%;">Action</th>
                                </tr>
                            </thead>
                            <tbody id="ABNTableContainer"></tbody>
                        </table>
                    </div>
                    <div id="spinner_loading" class="text-center mt-2" style="display: none">
                        <i class="fas fa-spinner fa-spin fa-lg" style="font-size:30pt;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== MODAL: ADD NEW ABNORMALITY ===== -->
<div id="modal_add" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color:#3dcd58">
                <h5 class="text-white"><i class="fa fa-info-circle mr-2"></i>Add New Abnormality</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="row ml-2 mr-2">
                    <div class="col-12">
                        <div class="card card-outline">
                            <div class="row ml-2 mr-2">
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Date<span style="color:red;">*</span></label>
                                        <input class="form-control form-control-sm" type="date" id="date_find" maxlength="255" />
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Facility<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="facility_id" style="width:100%;">
                                            <option>--- Select Facility ---</option>
                                            @foreach (var facility in ViewBag.Facility)
                                            {
                                                <option value="@facility.Code">@facility.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Line/Cell no<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="line" style="width:100%;">
                                            <option>--- Select Line/Cell no ---</option>
                                            @foreach (var line in ViewBag.Line)
                                            {
                                                <option value="@line.Code">@line.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Station ID<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="station" style="width:100%;">
                                            <option>--- Select Station ID ---</option>
                                            @foreach (var station in ViewBag.Station)
                                            {
                                                <option value="@station.Code">@station.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">TPM Tag<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="tpm_tag" style="width:100%;">
                                            <option>--- Select TPM Tag ---</option>
                                            @foreach (var tag in ViewBag.TpmTag)
                                            {
                                                <option value="@tag.Code" data-name="@tag.Name">@tag.Code</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Fixed by<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="fixed_myself" style="width:100%;">
                                            <option>--- Select ---</option>
                                            <option>Fixed by myself</option>
                                            <option>Action owner</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Tag Area<span style="color:red;">*</span></label>
                                        <input class="form-control form-control-sm" id="tag_id" disabled />
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Action Owner<span style="color:red;">*</span></label>
                                        <input class="form-control form-control-sm" id="action_owner_display" disabled />
                                        <input type="hidden" id="action_owner_sesa_hidden" name="ActionOwnerSesa" value="" />
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4" id="validated_by_container" style="display:none;">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Validated by<span style="color:red;">*</span></label>
                                        <input class="form-control form-control-sm" id="validated_by_display" disabled />
                                        <input type="hidden" id="validated_by_sesa_hidden" name="ValidatedBySesa" value="" />
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4" id="sesa_op_container">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Operator SESA<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="sesa_op" style="width:100%;">
                                            <option>--- Select Operator SESA ---</option>
                                            @foreach (var op in ViewBag.SesaOP)
                                            {
                                                <option value="@op.Code">@op.Code - @op.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Findings<span style="color:red;">*</span></label>
                                        <textarea class="form-control form-control-sm" id="finding" maxlength="255" style="resize:vertical; min-height:50px;" placeholder="no findings allowed."></textarea>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-1">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Finding picture<span style="color:red;">*</span></label>
                                        <div class="ml-1" id="finding_picture_section">
                                            <div class="row">
                                                <input type="file" name="file" accept=".jpg,.bmp,.png,.jfif" id="finding_file_input" hidden />
                                                <label for="finding_file_input" class="actual-btnn">Choose file</label>
                                            </div>
                                            <div class="row">
                                                <span id="finding_file_name_display" style="width:100%;">No file chosen</span>
                                                <button id="finding_file_reset_btn" class="reset-btnn" style="display:none;">Delete</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-1">
                                    <label style="font-size:10pt; font-weight:bold;">Preview</label>
                                    <div class="ml-1">
                                        <img id="finding_img_preview" src="" style="width:5rem; height:5rem; display:none;" />
                                    </div>
                                </div>

                                <div class="row ml-2 mr-2">
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Select Type of Abnormality<span style="color:red;">*</span></label>
                                            <select class="form-select form-select-sm text-center select2" id="abn_type_add" style="width:100%;">
                                                <option value="--- Select ---">--- Select ---</option>
                                                @foreach (var item in ViewBag.AbnType)
                                                {
                                                    <option value="@item.Code">@item.Name</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">What will happen if it is left as it is?<span style="color:red;">*</span></label>
                                            <select class="form-select form-select-sm text-center select2" id="abn_happen_add" style="width:100%;">
                                                <option value="--- Select ---">--- Select ---</option>
                                                @foreach (var item in ViewBag.AbnHappen)
                                                {
                                                    <option value="@item.Name">@item.Name</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Root Cause (Human Weakness)<span style="color:red;">*</span></label>
                                            <select class="form-select form-select-sm text-center select2" id="abn_rootcause_add" style="width:100%;">
                                                <option value="--- Select ---">--- Select ---</option>
                                                @foreach (var item in ViewBag.AbnRootCause)
                                                {
                                                    <option value="@item.Code">@item.Name</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Input root cause analysis<span style="color:red;">*</span></label>
                                            <textarea class="form-control form-control-sm" id="input_root_add" maxlength="255" style="resize:vertical; min-height:50px;"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields" style="display:none;">
                                        <label style="font-size:10pt; font-weight:bold;">Are this covered on AM checklist?<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="am_checklist_fixed_add" style="width:100%;">
                                            <option value="--- Select ---">--- Select ---</option>
                                            <option value="Y">Yes</option>
                                            <option value="N">No</option>
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 machine_input_container_add fixed-myself-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Input machine major part and machine sub part<span style="color:red;">*</span></label>
                                            <textarea class="form-control form-control-sm" id="input_machine_add" maxlength="255" style="resize:vertical; min-height:50px;"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields hideable-action-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Input countermeasure/corrective action<span style="color:red;">*</span></label>
                                            <textarea class="form-control form-control-sm" id="input_corrective_action_add" style="resize:vertical; min-height:50px;"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields hideable-action-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Target Completion<span style="color:red;">*</span></label>
                                            <input class="form-control form-control-sm" type="date" id="date_target_add" />
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields hideable-action-fields" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Attachment File ".pdf"</label>
                                            <input type="file" class="form-control pdfFile-form" name="FormFileAdd" id="pdfFile_add" accept=".pdf">
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields" style="display:none;">
                                        <label style="font-size:10pt; font-weight:bold;">Status<span style="color:red;">*</span></label>
                                        <input class="form-control form-control-sm" type="text" id="status_fixed_add" value="Open" disabled />
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-4 fixed-myself-fields mb-3" style="display:none;">
                                        <label style="font-size:10pt; font-weight:bold;">Assigned Action<span style="color:red;">*</span></label>
                                        <input class="form-control form-control-sm" type="text" id="assigned_action_fixed_add" value="Self Fixed" disabled />
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-1 fixed-myself-fields mt-3" style="display:none;">
                                        <div class="form-group">
                                            <label style="font-size:10pt; font-weight:bold;">Action Picture<span style="color:red;">*</span></label>
                                            <div class="ml-1" id="action_picture_section_add">
                                                <div class="row">
                                                    <input type="file" name="file_action_add" accept=".jpg,.bmp,.png,.jfif" id="action_file_input_add" hidden />
                                                    <label for="action_file_input_add" class="actual-btnn">Choose file</label>
                                                </div>
                                                <div class="row">
                                                    <span id="action_file_name_display_add" style="width:100%;">No file chosen</span>
                                                </div>
                                                <button id="action_file_reset_btn_add" class="btn btn-danger btn-sm mt-2" style="display:none;">Delete</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-1 fixed-myself-fields mt-3" style="display:none;">
                                        <label style="font-size:10pt; font-weight:bold;">Action Preview</label>
                                        <div class="ml-1">
                                            <img id="action_img_preview_add" src="" style="width:5rem; height:5rem; display:none;" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="row d-flex justify-content-center">
                            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                                <button class="btn btn-success btn-block" id="create_Data">
                                    <i class="fas fa-pen"></i> Submit
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== MODAL: ACTION OWNER ===== -->
<div id="modal_action" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color:#3dcd58">
                <h5 class="text-white"><i class="fa fa-info-circle mr-2"></i>Action Owner</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="row ml-2 mr-2">
                    <div class="col-12">
                        <div class="card card-outline">
                            <div class="row ml-2 mr-2">
                                <input type="hidden" id="hidden_facility_id" />
                                <input type="hidden" id="order_id" />
                                <div class="col-12 col-md-6 col-lg-3">
                                    <label style="font-size:10pt; font-weight:bold;">Facility</label>
                                    <input class="form-control form-control-sm display_facility" type="text" disabled />
                                </div>
                                <div class="col-12 col-md-6 col-lg-3">
                                    <label style="font-size:10pt; font-weight:bold;">Order ID</label>
                                    <input class="form-control form-control-sm display_order_id" type="text" disabled />
                                </div>
                                <div class="col-12 col-md-6 col-lg-3">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Select Type of Abnormality<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="abn_type" style="width:100%;">
                                            <option>--- Select ---</option>
                                            @foreach (var item in ViewBag.AbnType)
                                            {
                                                <option value="@item.Code">@item.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-3 abn-hideable-field">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">What will happen if it is left as it is?<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="abn_happen" style="width:100%;">
                                            <option>--- Select ---</option>
                                            @foreach (var item in ViewBag.AbnHappen)
                                            {
                                                <option value="@item.Name">@item.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-3 abn-hideable-field">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Root Cause (Human Weakness)<span style="color:red;">*</span></label>
                                        <select class="form-select form-select-sm text-center select2" id="abn_rootcause" style="width:100%;">
                                            <option>--- Select ---</option>
                                            @foreach (var item in ViewBag.AbnRootCause)
                                            {
                                                <option value="@item.Code">@item.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4 abn-hideable-field">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Input root cause analysis<span style="color:red;">*</span></label>
                                        <textarea class="form-control form-control-sm" id="input_root" maxlength="255" style="resize:vertical; min-height:50px;"></textarea>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4 abn-hideable-field machine_input_container" style="display:none;">
                                    <div class="form-group">
                                        <label style="font-size:10pt; font-weight:bold;">Input machine major part and machine sub part<span style="color:red;">*</span></label>
                                        <textarea class="form-control form-control-sm" id="input_machine" maxlength="255" style="resize:vertical; min-height:50px;"></textarea>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-2 abn-hideable-field">
                                    <label style="font-size:10pt; font-weight:bold;">Are this covered on AM checklist?<span style="color:red;">*</span></label>
                                    <select class="form-select form-select-sm text-center select2" id="am_checklist" style="width:100%;">
