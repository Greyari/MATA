@inject IHttpContextAccessor HttpContextAccessor
@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_LayoutMAT.cshtml";
}

@section Styles {
    <style>
        .green-background { background-color: #28a745 !important; }
        .modal-dialog      { max-width: 95% !important; }
    </style>
}

<!-- HERO HEADER -->
<partial name="_HeroHeader" model='("Dashboard", "/images/background/bgdashboard.jpg")' />

<div class="content pt-3">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">

                        <!-- Filter -->
                        <div class="row align-center" style="margin-bottom:20px; margin-left:15px; margin-right:15px;">
                            <div class="col-lg-3">
                                <label style="font-size:10pt; font-weight:bold;">Time Range</label>
                                <div id="range-btn-group" class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="range-options" id="range-daily"   value="Daily"   autocomplete="off">
                                    <label class="btn btn-sm btn-outline-secondary" for="range-daily">Daily</label>

                                    <input type="radio" class="btn-check" name="range-options" id="range-weekly"  value="Weekly"  autocomplete="off">
                                    <label class="btn btn-sm btn-outline-secondary" for="range-weekly">Weekly</label>

                                    <input type="radio" class="btn-check" name="range-options" id="range-monthly" value="Monthly" autocomplete="off">
                                    <label class="btn btn-sm btn-outline-secondary" for="range-monthly">Monthly</label>

                                    <input type="radio" class="btn-check" name="range-options" id="range-yearly"  value="Yearly"  autocomplete="off" checked>
                                    <label class="btn btn-sm btn-outline-secondary" for="range-yearly">Yearly</label>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <label style="font-size:10pt; font-weight:bold;">Facility</label>
                                <select class="selectpicker form-control" id="select_filter_2" multiple data-live-search="true" data-actions-box="true">
                                    @foreach (var item in ViewBag.Facilities)
                                    {
                                        <option value="@item.Code">@item.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label style="font-size:10pt; font-weight:bold;">Line</label>
                                <select class="selectpicker form-control" id="select_filter_3" multiple data-live-search="true" data-actions-box="true">
                                    @foreach (var item in ViewBag.Lines)
                                    {
                                        <option value="@item.Code">@item.Code</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label style="font-size:10pt; font-weight:bold;">Station ID</label>
                                <select class="selectpicker form-control" id="select_filter_4" multiple data-live-search="true" data-actions-box="true">
                                    @foreach (var item in ViewBag.Stations)
                                    {
                                        <option value="@item.Code">@item.Code</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label style="font-size:10pt; font-weight:bold;">Date From</label>
                                <input type="date" class="form-control form-control-sm" id="date_from">
                            </div>
                            <div class="col-md-2">
                                <label style="font-size:10pt; font-weight:bold;">Date To</label>
                                <input type="date" class="form-control form-control-sm" id="date_to">
                            </div>
                            <div class="col-md-2 align-center">
                                <button class="form-control form-control-sm" id="apply_filter"
                                    style="background-color:#28a745; color:white; margin-top:30px;">
                                    <i class="fas fa-arrow-right"></i> Apply Filter
                                </button>
                            </div>
                        </div>

                        <!-- Charts -->
                        @foreach (var chart in new[] {
                            ("Cavite Abnormalities Monitoring", "abn_monitoring"),
                            ("Total OPLs",                      "total_opls"),
                            ("% OPLs per site",                 "opls_per_site"),
                            ("Top 10 Sharp Eye in finding abnormalities", "sharp_eye"),
                            ("TPM Tag category",                "tpm_tag"),
                            ("Root Cause (Human Weakness)",     "rootcause"),
                            ("What will happen if it is left as it is", "happen"),
                            ("Seven Types of Abnormalities",    "abn_type"),
                            ("Top 10 Fixed by Self",            "fixed_by_self")
                        })
                        {
                            <div class="row">
                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header text-center bg-secondary" style="color:white; font-size:18px; font-weight:bold;">
                                            @chart.Item1
                                        </div>
                                        <div class="card-body">
                                            <div style="position:relative; height:450px; width:100%;">
                                                <canvas id="@chart.Item2"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Detail Table -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header green-background">
                <h5 class="modal-title text-white" id="detailsModalTitle"></h5>
                <h5 class="modal-title text-white ms-1"  id="sub_title"></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <table class="table table-sm table-striped" id="tbl_details_filter2">
                    <thead style="position:sticky; top:0; z-index:10;">
                        <tr class="text-center">
                            <th class="green-background text-white">Date</th>
                            <th class="green-background text-white">Facility</th>
                            <th class="green-background text-white">Line/Cell No</th>
                            <th class="green-background text-white">Station ID</th>
                            <th class="green-background text-white">TPM Tag</th>
                            <th class="green-background text-white">Operator Sesa</th>
                            <th class="green-background text-white">Findings</th>
                            <th class="green-background text-white">Picture</th>
                            <th class="green-background text-white">Attachment</th>
                            <th class="green-background text-white">Status</th>
                            <th class="green-background text-white">Action Owner</th>
                            <th class="green-background text-white">Validator</th>
                        </tr>
                    </thead>
                    <tbody id="TableContainer"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Picture -->
<div id="show_all_picture" class="modal fade" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fa fa-info-circle"></i> Picture</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="row mt-3 text-center">
                    <div class="col-6">
                        <h5 class="text-bold mb-2">Before (Findings)</h5>
                        <img id="img_before" style="width:80%">
                        <div class="form-group mt-2">
                            <label style="font-size:10pt; font-weight:bold;">Finding Remark <span style="color:red;">*</span></label>
                            <textarea class="form-control form-control-sm" id="remark_findings" maxlength="255" style="resize:vertical; min-height:50px;"></textarea>
                        </div>
                    </div>
                    <div class="col-6">
                        <h5 class="text-bold mb-2">After (Action)</h5>
                        <img id="img_after" style="width:80%">
                        <div class="form-group mt-2">
                            <label style="font-size:10pt; font-weight:bold;">Countermeasure Remark <span style="color:red;">*</span></label>
                            <textarea class="form-control form-control-sm" id="remark_countermeasure" maxlength="255" style="resize:vertical; min-height:50px;"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: PDF Viewer -->
<div id="view_pdf" class="modal fade" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fa fa-info-circle"></i> Attachment File</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <iframe id="pdfViewer" src="" style="width:100%; height:700px; border:none;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    Chart.register(ChartDataLabels);

    // ===== INSTANCE CHART =====
    var abnMonitoringChartInstance, totalOPLsChartInstance, oplsPerSiteChartInstance;
    var sharpEyeChartInstance, TpmTagChartInstance, RootCauseChartInstance;
    var HappenChartInstance, AbnTypeChartInstance, FixedSelfChartInstance;
    var detailTableInstance;

    // ===== INISIALISASI =====
    $(document).ready(function () {
        $('.selectpicker').selectpicker('selectAll');
        $('#date_from').val('2025-01-01');
        $('#date_to').val('2026-12-31');
        setTimeout(loadAllData, 100);

        $('#apply_filter').off('click').on('click', loadAllData);
    });

    $(document).on('hidden.bs.modal', function () {
        if ($('.modal:visible').length) $('body').addClass('modal-open');
    });

    // ===== HELPER: Ambil filter aktif =====
    function getFilters() {
        return {
            facility:  ($('#select_filter_2').val() || []).join(','),
            line:      ($('#select_filter_3').val() || []).join(','),
            station:   ($('#select_filter_4').val() || []).join(','),
            date_from: $('#date_from').val(),
            date_to:   $('#date_to').val(),
            range:     $('input[name="range-options"]:checked').val()
        };
    }

    // ===== HELPER: Buat bar chart standar =====
    function buildBarChart(canvasId, instance, labels, data, onClick) {
        return new Chart(document.getElementById(canvasId), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Findings',
                    data: data,
                    backgroundColor: '#dc3545',
                    borderColor: '#dc3545',
                    borderWidth: 1,
                    barPercentage: 0.7,
                    categoryPercentage: 0.8,
                    minBarLength: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {},
                    y: { beginAtZero: true, grace: '10%' }
                },
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        anchor: 'end', align: 'top',
                        formatter: v => v > 0 ? v : '',
                        color: '#333',
                        font: { weight: 'bold', size: 15 }
                    }
                },
                onClick: (event, elements) => {
                    if (elements.length > 0) onClick(instance.data.labels[elements[0].index]);
                }
            },
            plugins: [ChartDataLabels]
        });
    }

    // ===== LOAD ALL =====
    function loadAllData() {
        getAbnMonitoring();
        getTotalOPLs();
        getOPLsPerSite();
        getSharpEye();
        getTPMTag();
        getRootCause();
        getHappen();
        getAbnType();
        getFixedSelf();
    }

    // ===== CHART: Abn Monitoring =====
    function getAbnMonitoring() {
        if (abnMonitoringChartInstance) { abnMonitoringChartInstance.destroy(); abnMonitoringChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_FINDING_CLOSED", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], dataFindings = [], dataClosed = [];
                (data || []).forEach(item => {
                    labels.push(item.Period_Group);
                    dataFindings.push(parseFloat(item.Findings) || 0);
                    dataClosed.push(parseFloat(item.Closed) || 0);
                });
                abnMonitoringChartInstance = new Chart(document.getElementById('abn_monitoring'), {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [
                            { label: 'Findings', data: dataFindings, backgroundColor: '#dc3545', borderColor: '#dc3545', borderWidth: 1, barPercentage: 0.7, categoryPercentage: 0.8, minBarLength: 5 },
                            { label: 'Closed',   data: dataClosed,   backgroundColor: '#28a745', borderColor: '#28a745', borderWidth: 1, barPercentage: 0.7, categoryPercentage: 0.8, minBarLength: 5 }
                        ]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        scales: { x: {}, y: { beginAtZero: true, grace: '10%' } },
                        plugins: {
                            legend: { display: true, position: 'bottom', labels: { usePointStyle: true, padding: 20 } },
                            datalabels: { anchor: 'end', align: 'top', formatter: v => v > 0 ? v : '', color: '#333', font: { weight: 'bold', size: 15 } },
                            title: { display: true, text: 'Findings vs Closed Status' }
                        },
                        onClick: (event, elements) => {
                            if (elements.length > 0) {
                                const label        = abnMonitoringChartInstance.data.labels[elements[0].index];
                                const type         = abnMonitoringChartInstance.data.datasets[elements[0].datasetIndex].label;
                                actionDetailAbnMonitor(label, type);
                            }
                        }
                    },
                    plugins: [ChartDataLabels]
                });
            }
        });
    }

    // ===== CHART: Total OPLs =====
    function getTotalOPLs() {
        if (totalOPLsChartInstance) { totalOPLsChartInstance.destroy(); totalOPLsChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_TOTAL_OPLs", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], dataAccumulative = [], dataClosed = [];
                (data || []).forEach(item => {
                    labels.push(item.Period_Group);
                    dataAccumulative.push(item.Accumulative);
                    dataClosed.push(item.Closed);
                });
                let maxAcc = Math.max(...dataAccumulative, 0) || 100;
                totalOPLsChartInstance = new Chart(document.getElementById('total_opls'), {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [
                            { type: 'line', label: 'Cumulative Total', data: dataAccumulative, yAxisID: 'y',     borderColor: '#000', backgroundColor: '#000', borderWidth: 2, tension: 0.1, pointRadius: 0, fill: false, order: 0, datalabels: { display: false } },
                            { type: 'bar',  label: 'Monthly Closed',   data: dataClosed,       yAxisID: 'y_bar', backgroundColor: '#28a745', borderColor: '#28a745', borderWidth: 1, barPercentage: 0.6, order: 1, datalabels: { anchor: 'end', align: 'top', color: '#333', formatter: v => v > 0 ? v : '' } }
                        ]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        scales: {
                            y:     { type: 'linear', display: true,  position: 'left',  beginAtZero: true, max: maxAcc * 1.1, ticks: { stepSize: 20 } },
                            y_bar: { type: 'linear', display: false, position: 'right', beginAtZero: true, max: maxAcc * 2.5, grid: { display: false } }
                        },
                        plugins: {
                            legend: { display: false },
                            datalabels: { color: '#333', font: { weight: 'bold', size: 15 } }
                        },
                        onClick: (event, elements) => {
                            if (elements.length > 0) actionDetailTotalOPLs(totalOPLsChartInstance.data.labels[elements[0].index]);
                        }
                    },
                    plugins: [ChartDataLabels]
                });
            }
        });
    }

    // ===== CHART: OPLs Per Site (Doughnut) =====
    function getOPLsPerSite() {
        if (oplsPerSiteChartInstance) { oplsPerSiteChartInstance.destroy(); oplsPerSiteChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_OPLS_PER_SITE", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], dataVal = [], colors = [];
                const palette = ['#dc3545','#0d6efd','#198754','#ffc107','#0dcaf0','#6610f2','#fd7e14','#20c997','#e83e8c','#6f42c1'];
                (data || []).forEach((item, i) => {
                    labels.push(item.Facility);
                    dataVal.push(parseFloat(item.Closed) || 0);
                    colors.push(palette[i % palette.length]);
                });
                oplsPerSiteChartInstance = new Chart(document.getElementById('opls_per_site'), {
                    type: 'doughnut',
                    data: { labels, datasets: [{ data: dataVal, backgroundColor: colors, borderColor: '#fff', borderWidth: 2, hoverOffset: 4 }] },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: {
                            legend: { display: true, position: 'bottom', labels: { usePointStyle: true, padding: 20 } },
                            datalabels: { color: '#fff', anchor: 'center', align: 'center', formatter: v => v > 0 ? v : '', font: { weight: 'bold', size: 18 } },
                            tooltip: { callbacks: { label: ctx => { let total = ctx.chart._metasets[ctx.datasetIndex].total; return `${ctx.label}: ${ctx.raw} (${Math.round(ctx.raw/total*100)}%)`; } } }
                        },
                        onClick: (event, elements) => {
                            if (elements.length > 0) actionDetailOPLsPerSite(oplsPerSiteChartInstance.data.labels[elements[0].index]);
                        }
                    },
                    plugins: [ChartDataLabels]
                });
            }
        });
    }

    // ===== CHART: Sharp Eye =====
    function getSharpEye() {
        if (sharpEyeChartInstance) { sharpEyeChartInstance.destroy(); sharpEyeChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_SHARP_EYE", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], vals = [];
                (data || []).forEach(item => { labels.push(item.FindingName); vals.push(parseFloat(item.BarChart) || 0); });
                sharpEyeChartInstance = buildBarChart('sharp_eye', sharpEyeChartInstance, labels, vals, actionDetailSharpEye);
            }
        });
    }

    // ===== CHART: TPM Tag =====
    function getTPMTag() {
        if (TpmTagChartInstance) { TpmTagChartInstance.destroy(); TpmTagChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_TPM_TAG", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], vals = [];
                (data || []).forEach(item => { labels.push(item.TagId); vals.push(parseFloat(item.BarChart) || 0); });
                TpmTagChartInstance = buildBarChart('tpm_tag', TpmTagChartInstance, labels, vals, actionDetailTpmTag);
            }
        });
    }

    // ===== CHART: Root Cause =====
    function getRootCause() {
        if (RootCauseChartInstance) { RootCauseChartInstance.destroy(); RootCauseChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_ROOTCAUSE", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], vals = [];
                (data || []).forEach(item => { labels.push(item.AbnRootCause); vals.push(parseFloat(item.BarChart) || 0); });
                RootCauseChartInstance = buildBarChart('rootcause', RootCauseChartInstance, labels, vals, actionDetailRootCause);
            }
        });
    }

    // ===== CHART: Happen =====
    function getHappen() {
        if (HappenChartInstance) { HappenChartInstance.destroy(); HappenChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_HAPPEN", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], vals = [];
                (data || []).forEach(item => { labels.push(item.AbnHappen); vals.push(parseFloat(item.BarChart) || 0); });
                HappenChartInstance = buildBarChart('happen', HappenChartInstance, labels, vals, actionDetailHappen);
            }
        });
    }

    // ===== CHART: Abn Type =====
    function getAbnType() {
        if (AbnTypeChartInstance) { AbnTypeChartInstance.destroy(); AbnTypeChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_ABN_TYPE", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], vals = [];
                (data || []).forEach(item => { labels.push(item.AbnType); vals.push(parseFloat(item.BarChart) || 0); });
                AbnTypeChartInstance = buildBarChart('abn_type', AbnTypeChartInstance, labels, vals, actionDetailAbnType);
            }
        });
    }

    // ===== CHART: Fixed by Self =====
    function getFixedSelf() {
        if (FixedSelfChartInstance) { FixedSelfChartInstance.destroy(); FixedSelfChartInstance = null; }
        $.ajax({
            type: "POST", cache: false,
            url: "@Url.Action("GET_FIXED_BY_SELF", "Dashboard")",
            data: getFilters(),
            success: function (data) {
                let labels = [], vals = [];
                (data || []).forEach(item => { labels.push(item.FindingName); vals.push(parseFloat(item.BarChart) || 0); });
                FixedSelfChartInstance = buildBarChart('fixed_by_self', FixedSelfChartInstance, labels, vals, actionDetailFixedSelf);
            }
        });
    }

    // ===== ACTION DETAIL: Buka modal & load tabel =====
    function actionDetailAbnMonitor(v, type) { $('#detailsModalTitle').text('Cavite Abnormalities Monitoring'); $('#detailModal').modal('show'); getDetail2Param(v, type, '@Url.Action("GET_DETAIL_FINDING_CLOSED", "Dashboard")'); }
    function actionDetailTotalOPLs(v)        { $('#detailsModalTitle').text('Total OPLs');                       $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_OPLS", "Dashboard")'); }
    function actionDetailOPLsPerSite(v)      { $('#detailsModalTitle').text('OPLs per site');                    $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_OPLS_PER_SITE", "Dashboard")'); }
    function actionDetailSharpEye(v)         { $('#detailsModalTitle').text('Top 10 Sharp Eye');                 $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_SHARP_EYE", "Dashboard")'); }
    function actionDetailTpmTag(v)           { $('#detailsModalTitle').text('TPM Tag category');                 $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_TPM_TAG", "Dashboard")'); }
    function actionDetailRootCause(v)        { $('#detailsModalTitle').text('Root Cause');                       $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_ROOTCAUSE", "Dashboard")'); }
    function actionDetailHappen(v)           { $('#detailsModalTitle').text('What will happen');                 $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_HAPPEN", "Dashboard")'); }
    function actionDetailAbnType(v)          { $('#detailsModalTitle').text('Seven Types of Abnormalities');     $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_ABN_TYPE", "Dashboard")'); }
    function actionDetailFixedSelf(v)        { $('#detailsModalTitle').text('Top 10 Fixed by Self');             $('#detailModal').modal('show'); getDetail1Param(v, '@Url.Action("GET_DETAIL_FIXED_BY_SELF", "Dashboard")'); }

    // ===== HELPER: Zoom gambar =====
    function zoomAllImage(image, picture, findings, corrective) {
        var alt_img  = '@Url.Content("~/assets/notavailable.png")';
        var basePath = '@Url.Content("~/upload/img/abn/")';
        $('#show_all_picture').modal('show');
        $('#img_before').attr('src', basePath + picture).attr('onerror', `this.onerror=null;this.src='${alt_img}';`);
        $('#img_after').attr('src',  basePath + image  ).attr('onerror', `this.onerror=null;this.src='${alt_img}';`);
        $('#remark_findings').val(findings);
        $('#remark_countermeasure').val(corrective);
    }

    // ===== HELPER: View PDF =====
    function viewPdf(attachment_file) {
        $('#view_pdf').modal('show');
        $('#pdfViewer').attr('src', '@Url.Content("~/upload/img/abn/pdf/")' + attachment_file);
    }

    // ===== HELPER: Load detail tabel (1 param) =====
    function getDetail1Param(value, controlTarget) {
        $('#TableContainer').hide();
        $.ajax({
            type: "POST", cache: false,
            url: controlTarget,
            data: { ...getFilters(), value },
            success: function (result) {
                $('#sub_title').text('(' + value + ')');
                if (detailTableInstance) detailTableInstance.destroy();
                $('#TableContainer').html(result).show();
                detailTableInstance = $('#tbl_details_filter2').DataTable({ responsive: true, autoWidth: false, searching: true, paging: true, ordering: true, order: [[1, 'asc']] });
            },
            error: function () {
                $('#TableContainer').html('<div class="alert alert-danger">Error loading data. Please try again.</div>').show();
            }
        });
    }

    // ===== HELPER: Load detail tabel (2 param) =====
    function getDetail2Param(value, type, controlTarget) {
        $('#TableContainer').hide();
        $.ajax({
            type: "POST", cache: false,
            url: controlTarget,
            data: { ...getFilters(), value, type },
            success: function (result) {
                $('#sub_title').text('(' + value + ' & ' + type + ')');
                if (detailTableInstance) detailTableInstance.destroy();
                $('#TableContainer').html(result).show();
                detailTableInstance = $('#tbl_details_filter2').DataTable({ responsive: true, autoWidth: false, searching: true, paging: true, ordering: true, order: [[1, 'asc']] });
            },
            error: function () {
                $('#TableContainer').html('<div class="alert alert-danger">Error loading data. Please try again.</div>').show();
            }
        });
    }
</script>
}