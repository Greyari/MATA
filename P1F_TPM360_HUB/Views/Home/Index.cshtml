@model P1F_TPM360_HUB.Models.LoginModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using Microsoft.AspNetCore.Http
@using System.Security.Claims

@{
    string sesaId       = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    string name         = User.FindFirst("P1F_TPM360_HUB_name")?.Value;
    string level        = User.FindFirst("P1F_TPM360_HUB_level")?.Value;
    bool   isRegistered = level != null;

    Layout = null;
    var nonce = Context.Items["CspNonce"] as string;

    bool hasError = TempData["MessageSSO"] != null || ViewData["Message"] != null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TPM360 Hub – Login</title>

    <link rel="icon" type="image/x-icon" href="~/images/icon/seicongreenwstroke.svg">

    <!-- AdminLTE & Plugins -->
    <link href="~/lib/adminlte/plugins/fontawesome-free/css/all.css"        rel="stylesheet" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.css"                     rel="stylesheet" />
    <link href="~/lib/adminlte/dist/css/adminlte.min.css"                   rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/sweetalert2/sweetalert2.css"         rel="stylesheet" />
    <link rel="stylesheet" href="~/css/custom-fonts.css" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
</head>

<!-- BODY: full-page background with centered flex layout -->
<body style="
    font-family: 'DM Sans', sans-serif;
    background:
        linear-gradient(160deg, rgba(0,0,0,.75) 0%, rgba(0,0,0,.55) 100%),
        url('@Url.Content("~/images/background/maintenance.jpg")') no-repeat center center / cover fixed;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    margin: 0;
    box-sizing: border-box;
">

    <!-- WRAPPER: max-width container -->
    <div style="width: 100%; max-width: 900px;">

        <!-- CARD: two-column grid layout -->
        <div style="
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 24px 60px rgba(0,0,0,.35);
            min-height: 520px;
        ">

            <!-- ===== LEFT PANEL — Branding ===== -->
            <div style="
                position: relative;
                overflow: hidden;
                background:
                    linear-gradient(145deg, rgba(103,98,98,0.75) 0%, rgba(26,35,50,.70) 100%),
                    url('@Url.Content("~/images/background/bg-sere.jpg")') no-repeat center center / cover;
                color: #fff;
            ">
                <!-- Inner padding & flex layout -->
                <div style="
                    position: relative;
                    z-index: 2;
                    padding: 3rem 2.5rem;
                    height: 100%;
                    display: flex;
                    flex-direction: column;
                    justify-content: space-between;
                ">
                    <!-- Brand tagline pushed to bottom -->
                    <div style="margin-top: auto; padding-top: 2rem;">
                        <!-- App name -->
                        <p style="
                            font-family: 'Sora', sans-serif;
                            font-size: 1.15rem;
                            font-weight: 600;
                            line-height: 1.4;
                            color: #fff;
                            margin: 0;
                        ">Machine Abnormality<br>Tracking Application</p>

                        <!-- Company name -->
                        <p style="
                            font-size: .82rem;
                            color: #3dcd58;
                            margin-top: .35rem;
                            letter-spacing: .04em;
                            text-transform: uppercase;
                            margin-bottom: 0;
                        ">Schneider Electric Philippines</p>
                    </div>
                </div>

                <!-- Decorative circle 1 (top-right glow) -->
                <div aria-hidden="true" style="
                    position: absolute;
                    border-radius: 50%;
                    z-index: 1;
                    pointer-events: none;
                    width: 280px; height: 280px;
                    background: radial-gradient(circle, rgba(61,205,88,.18) 0%, transparent 70%);
                    top: -80px; right: -80px;
                "></div>

                <!-- Decorative circle 2 (bottom-left glow) -->
                <div aria-hidden="true" style="
                    position: absolute;
                    border-radius: 50%;
                    z-index: 1;
                    pointer-events: none;
                    width: 180px; height: 180px;
                    background: radial-gradient(circle, rgba(61,205,88,.1) 0%, transparent 70%);
                    bottom: 30px; left: -40px;
                "></div>
            </div>
            <!-- /LEFT PANEL -->


            <!-- ===== RIGHT PANEL — Login Form ===== -->
            <div style="background: #fff; position: relative; overflow: hidden;">

                <!-- Inner padding & centered flex -->
                <div style="
                    position: relative;
                    z-index: 2;
                    padding: 3rem 2.5rem;
                    height: 100%;
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    gap: 1.25rem;
                ">
                    <!-- Schneider Electric logo -->
                    <img src="~/assets/logo.png" alt="Schneider Electric" style="
                        width: 110px;
                        height: auto;
                        margin-bottom: .5rem;
                    ">

                    <!-- Heading block -->
                    <div>
                        <!-- Main heading -->
                        <h1 style="
                            font-family: 'Sora', sans-serif;
                            font-size: 1.6rem;
                            font-weight: 700;
                            color: #1a2332;
                            line-height: 1.2;
                            margin: 0;
                        ">Welcome Back</h1>

                        <!-- Sub heading -->
                        <p style="
                            font-size: .85rem;
                            color: #6b7a90;
                            margin-top: .3rem;
                            margin-bottom: 0;
                        ">Sign in to continue to TPM360 Hub</p>
                    </div>

                    <!-- ─── SSO Error alert ─── -->
                    @if (TempData["MessageSSO"] != null)
                    {
                        <div role="alert" style="
                            padding: .75rem 1rem;
                            border-radius: 8px;
                            font-size: .84rem;
                            line-height: 1.45;
                            background: #fff2f2;
                            border: 1px solid #fecaca;
                            color: #b91c1c;
                        ">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @Html.Raw(TempData["MessageSSO"])
                        </div>
                    }

                    <!-- ─── ViewData Error alert ─── -->
                    @if (ViewData["Message"] != null)
                    {
                        <div role="alert" style="
                            padding: .75rem 1rem;
                            border-radius: 8px;
                            font-size: .84rem;
                            line-height: 1.45;
                            background: #fff2f2;
                            border: 1px solid #fecaca;
                            color: #b91c1c;
                        ">
                            <i class="fas fa-lock me-2"></i>
                            You don't have access. Please contact admin for support.
                        </div>
                    }

                    <!-- ─── SESA Login Button (hidden when SSO error exists) ─── -->
                    @if (TempData["MessageSSO"] == null)
                    {
                        <button
                            class="btn-sesa"
                            onclick="openLoginModal()"
                            type="button"
                            style="
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                width: 100%;
                                padding: .85rem 1.5rem;
                                background: linear-gradient(135deg, #3dcd58 0%, #2ba344 100%);
                                color: #fff;
                                font-family: 'Sora', sans-serif;
                                font-size: .92rem;
                                font-weight: 600;
                                border: none;
                                border-radius: 10px;
                                cursor: pointer;
                                box-shadow: 0 4px 14px rgba(61,205,88,.35);
                                transition: transform .2s, box-shadow .2s, filter .2s;
                            "
                        >
                            <i class="fas fa-sign-in-alt me-2"></i>
                            Login with SESA
                        </button>
                    }

                </div>
            </div>
            <!-- /RIGHT PANEL -->

        </div>
        <!-- /CARD -->

    </div>
    <!-- /WRAPPER -->


    <!-- ===== MODAL — SESA Login ===== -->
    <div class="modal fade" id="modal_login" tabindex="-1" aria-labelledby="modal_login_label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">

            <!-- Modal container -->
            <div style="
                border: none;
                border-radius: 16px;
                overflow: hidden;
            " class="modal-content">

                <!-- Modal header -->
                <div class="modal-header" style="
                    background: #1a2332;
                    color: #fff;
                    padding: 1rem 1.25rem;
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    border-bottom: none;
                ">
                    <!-- Title -->
                    <h5 class="modal-title" id="modal_login_label" style="
                        font-family: 'Sora', sans-serif;
                        font-size: .95rem;
                        font-weight: 600;
                        margin: 0;
                    ">
                        <i class="fas fa-sign-in-alt mr-2 me-2 text-success"></i>SESA Login
                    </h5>

                    <!-- Close button -->
                    <button
                        type="button"
                        class="btn-close-modal"
                        data-dismiss="modal"
                        aria-label="Close"
                        style="
                            background: none;
                            border: none;
                            color: rgba(255,255,255,.6);
                            cursor: pointer;
                            font-size: 1rem;
                            line-height: 1;
                            padding: .25rem;
                            transition: color .15s;
                        "
                    >
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <!-- Modal body -->
                <div class="modal-body" style="padding: 1.75rem 1.5rem;">
                    <form id="form_login" method="post" action="@Url.Action("Login", "Home")" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- SESA ID field -->
                        <div style="margin-bottom: 1.1rem;">
                            <label for="sesa_id" style="
                                display: block;
                                font-size: .8rem;
                                font-weight: 600;
                                color: #1a2332;
                                margin-bottom: .4rem;
                                letter-spacing: .03em;
                                text-transform: uppercase;
                            ">SESA ID</label>
                            @Html.TextBoxFor(m => m.sesa_id, new {
                                @class       = "field-input",
                                id           = "sesa_id",
                                placeholder  = "SESA*****",
                                autocomplete = "username",
                                style        = "width:100%;padding:.65rem .9rem;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.9rem;font-family:'DM Sans',sans-serif;color:#1a2332;background:#f4f7fa;outline:none;"
                            })
                        </div>

                        <!-- Password field -->
                        <div style="margin-bottom: 1.1rem;">
                            <label for="password" style="
                                display: block;
                                font-size: .8rem;
                                font-weight: 600;
                                color: #1a2332;
                                margin-bottom: .4rem;
                                letter-spacing: .03em;
                                text-transform: uppercase;
                            ">Password</label>
                            @Html.PasswordFor(m => m.password, new {
                                @class       = "field-input",
                                id           = "password",
                                placeholder  = "••••••••",
                                autocomplete = "current-password",
                                style        = "width:100%;padding:.65rem .9rem;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.9rem;font-family:'DM Sans',sans-serif;color:#1a2332;background:#f4f7fa;outline:none;"
                            })
                        </div>

                        <!-- Submit button -->
                        <div style="display:flex; gap:.75rem; margin-top:1.5rem;">
                            <button
                                type="submit"
                                class="btn-submit"
                                style="
                                    flex: 2;
                                    padding: .65rem;
                                    border: none;
                                    border-radius: 10px;
                                    background: linear-gradient(135deg, #3dcd58 0%, #2ba344 100%);
                                    color: #fff;
                                    font-family: 'Sora', sans-serif;
                                    font-size: .875rem;
                                    font-weight: 600;
                                    cursor: pointer;
                                    box-shadow: 0 3px 10px rgba(61,205,88,.3);
                                    transition: transform .15s, box-shadow .15s, filter .15s;
                                "
                            >
                                Sign In <i class="fas fa-arrow-right ms-1"></i>
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>
    <!-- /MODAL -->


    <!-- ===== SCRIPTS ===== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="~/lib/adminlte/plugins/sweetalert2/sweetalert2.min.js"></script>

    <script>
        /* Open login modal */
        function openLoginModal() {
            $("#modal_login").modal("show");
        }

        /* AJAX form submit */
        $("#form_login").on("submit", function (e) {
            e.preventDefault();

            const $btn = $(this).find('button[type="submit"]');
            $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-1"></i> Signing in…');

            $.ajax({
                url:  $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        window.location.href = res.redirectUrl;
                    } else {
                        Swal.fire({ icon: "error", title: "Login Failed", text: res.message });
                        $btn.prop("disabled", false).html('Sign In <i class="fas fa-arrow-right ms-1"></i>');
                    }
                },
                error: function () {
                    Swal.fire({ icon: "error", title: "Error", text: "Something went wrong. Please check your connection." });
                    $btn.prop("disabled", false).html('Sign In <i class="fas fa-arrow-right ms-1"></i>');
                }
            });
        });
    </script>


    <!-- ===== MINIMAL STYLE — hanya untuk hover, focus, dan responsive (tidak bisa pakai inline) ===== -->
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        /* Hover & active untuk tombol SESA */
        .btn-sesa:hover  { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(61,205,88,.45); filter: brightness(1.05); }
        .btn-sesa:active { transform: translateY(0); }

        /* Hover untuk tombol close modal */
        .btn-close-modal:hover { color: #fff; }

        /* Focus untuk input field */
        .field-input:focus {
            border-color: #3dcd58 !important;
            box-shadow: 0 0 0 3px rgba(61,205,88,.15) !important;
            background: #fff !important;
        }
        .field-input::placeholder { color: #b0bac6; }

        /* Hover & disabled untuk tombol submit */
        .btn-submit:hover    { transform: translateY(-1px); box-shadow: 0 5px 14px rgba(61,205,88,.4); filter: brightness(1.05); }
        .btn-submit:disabled { opacity: .7; cursor: not-allowed; transform: none; }

        /* Responsive — tidak bisa pakai inline style */
        @@media (max-width: 650px) {
            .login-card { grid-template-columns: 1fr !important; }

            .login-panel--left .panel-inner {
                padding: 2.5rem 2rem 2rem !important;
                flex-direction: row !important;
                align-items: center !important;
                gap: 1rem !important;
                min-height: unset !important;
            }

            .login-panel--right .panel-inner {
                padding: 2rem 1.75rem 2.5rem !important;
            }
        }
    </style>

</body>
</html>
