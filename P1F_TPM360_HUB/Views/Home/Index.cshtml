@model P1F_TPM360_HUB.Models.LoginModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using Microsoft.AspNetCore.Http
@using System.Security.Claims

@{
    string sesaId   = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    string name     = User.FindFirst("P1F_TPM360_HUB_name")?.Value;
    string level    = User.FindFirst("P1F_TPM360_HUB_level")?.Value;
    bool   isRegistered = level != null;

    Layout = null;
    var nonce = Context.Items["CspNonce"] as string;

    bool hasError   = TempData["MessageSSO"] != null || ViewData["Message"] != null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TPM360 Hub – Login</title>

    <link rel="icon" type="image/x-icon" href="~/images/icon/seicongreenwstroke.svg">

    <!-- AdminLTE & Plugins -->
    <link href="~/lib/adminlte/plugins/fontawesome-free/css/all.css"        rel="stylesheet" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.css"                     rel="stylesheet" />
    <link href="~/lib/adminlte/dist/css/adminlte.min.css"                   rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/sweetalert2/sweetalert2.css"         rel="stylesheet" />
    <link rel="stylesheet" href="~/css/custom-fonts.css" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
</head>

<body class="login-bg">

    <!-- ===== MAIN WRAPPER ===== -->
    <div class="login-wrapper">

        <!-- ===== CARD ===== -->
        <div class="login-card">

            <!-- LEFT PANEL — Branding -->
            <div class="login-panel login-panel--left">
                <div class="panel-inner">
                    <div class="brand-tagline">
                        <p class="tagline-title">Machine Abnormality<br>Tracking Application</p>
                        <p class="tagline-sub">Schneider Electric Philippines</p>
                    </div>
                </div>

                <!-- decorative shapes -->
                <div class="deco deco--circle-1" aria-hidden="true"></div>
                <div class="deco deco--circle-2" aria-hidden="true"></div>
            </div>

            <!-- RIGHT PANEL — Login Form -->
            <div class="login-panel login-panel--right">
                <div class="panel-inner">

                    <!-- SE Logo -->
                    <img src="~/assets/logo.png" alt="Schneider Electric" class="se-logo">

                    <!-- Heading -->
                    <div class="login-heading">
                        <h1 class="greeting">Welcome Back</h1>
                        <p class="sub-greeting">Sign in to continue to TPM360 Hub</p>
                    </div>

                    <!-- ─── SSO Error ─── -->
                    @if (TempData["MessageSSO"] != null)
                    {
                        <div class="alert-box alert-box--danger" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @Html.Raw(TempData["MessageSSO"])
                        </div>
                    }

                    <!-- ─── ViewData Error ─── -->
                    @if (ViewData["Message"] != null)
                    {
                        <div class="alert-box alert-box--danger" role="alert">
                            <i class="fas fa-lock me-2"></i>
                            You don't have access. Please contact admin for support.
                        </div>
                    }

                    <!-- ─── Login Button (shown only when no SSO error) ─── -->
                    @if (TempData["MessageSSO"] == null)
                    {
                        <button class="btn-sesa" onclick="openLoginModal()" type="button">
                            <i class="fas fa-sign-in-alt me-2"></i>
                            Login with SESA
                        </button>
                    }
                </div>
            </div>

        </div>
        <!-- /login-card -->

    </div>
    <!-- /login-wrapper -->


    <!-- ===== MODAL — SESA Login ===== -->
    <div class="modal fade" id="modal_login" tabindex="-1" aria-labelledby="modal_login_label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content login-modal">

                <div class="modal-header">
                    <h5 class="modal-title" id="modal_login_label">
                        <i class="fas fa-sign-in-alt mr-2 me-2 text-success"></i>SESA Login
                    </h5>
                    <button type="button" class="btn-close-modal" data-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="modal-body">
                    <form id="form_login" method="post" action="@Url.Action("Login", "Home")" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="field-group">
                            <label for="sesa_id" class="field-label">SESA ID</label>
                            @Html.TextBoxFor(m => m.sesa_id, new {
                                @class       = "field-input",
                                id           = "sesa_id",
                                placeholder  = "SESA*****",
                                autocomplete = "username"
                            })
                        </div>

                        <div class="field-group">
                            <label for="password" class="field-label">Password</label>
                            @Html.PasswordFor(m => m.password, new {
                                @class       = "field-input",
                                id           = "password",
                                placeholder  = "••••••••",
                                autocomplete = "current-password"
                            })
                        </div>

                        <div class="modal-actions">
                            <button type="submit" class="btn-submit">
                                Sign In <i class="fas fa-arrow-right ms-1"></i>
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>
    <!-- /modal -->


    <!-- ===== SCRIPTS ===== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="~/lib/adminlte/plugins/sweetalert2/sweetalert2.min.js"></script>

    <script>
        /* ─── Open login modal ─── */
        function openLoginModal() {
            $("#modal_login").modal("show");
        }

        /* ─── AJAX form submit ─── */
        $("#form_login").on("submit", function (e) {
            e.preventDefault();

            const $btn = $(this).find('button[type="submit"]');
            $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-1"></i> Signing in…');

            $.ajax({
                url:  $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        window.location.href = res.redirectUrl;
                    } else {
                        Swal.fire({ icon: "error", title: "Login Failed", text: res.message });
                        $btn.prop("disabled", false).html('Sign In <i class="fas fa-arrow-right ms-1"></i>');
                    }
                },
                error: function () {
                    Swal.fire({ icon: "error", title: "Error", text: "Something went wrong. Please check your connection." });
                    $btn.prop("disabled", false).html('Sign In <i class="fas fa-arrow-right ms-1"></i>');
                }
            });
        });
    </script>


    <!-- ===== STYLES ===== -->
    <style>
        /* ── Variables ────────────────────────────────────────────── */
        :root {
            --se-green:    #3dcd58;
            --se-green-dk: #2ba344;
            --se-dark:     #1a2332;
            --se-darker:   #111921;
            --se-muted:    #6b7a90;
            --se-light:    #f4f7fa;
            --radius-card: 20px;
            --radius-btn:  10px;
            --font-main:   'Sora', sans-serif;
            --font-body:   'DM Sans', sans-serif;
            --shadow-card: 0 24px 60px rgba(0,0,0,.35);
        }

        /* ── Reset / Base ─────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body.login-bg {
            font-family: var(--font-body);
            background:
                linear-gradient(160deg, rgba(0,0,0,.75) 0%, rgba(0,0,0,.55) 100%),
                url('@Url.Content("~/images/background/maintenance.jpg")') no-repeat center center / cover fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        /* ── Card wrapper ─────────────────────────────────────────── */
        .login-wrapper {
            width: 100%;
            max-width: 900px;
        }

        .login-card {
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-radius: var(--radius-card);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            min-height: 520px;
        }

        /* ── Panels ───────────────────────────────────────────────── */
        .login-panel {
            position: relative;
            overflow: hidden;
        }

        .panel-inner {
            position: relative;
            z-index: 2;
            padding: 3rem 2.5rem;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        /* LEFT — dark branded panel */
        .login-panel--left {
            background:
                linear-gradient(145deg, rgba(103, 98, 98, 0.75) 0%, rgba(26,35,50,.70) 100%),
                url('@Url.Content("~/images/background/bg-sere.jpg")') no-repeat center center / cover;
            color: #fff;
        }

        .login-panel--left .panel-inner {
            justify-content: space-between;
        }

        .brand-logo {
            width: 65%;
            max-width: 220px;
            height: auto;
            filter: brightness(1.1);
        }

        .brand-tagline {
            margin-top: auto;
            padding-top: 2rem;
        }

        .tagline-title {
            font-family: var(--font-main);
            font-size: 1.15rem;
            font-weight: 600;
            line-height: 1.4;
            color: #fff;
        }

        .tagline-sub {
            font-size: .82rem;
            color: var(--se-green);
            margin-top: .35rem;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .badge-version {
            display: inline-block;
            margin-top: 1.5rem;
            padding: .25rem .75rem;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 999px;
            font-size: .72rem;
            color: rgba(255,255,255,.55);
            letter-spacing: .06em;
        }

        /* Decorative circles on the left panel */
        .deco {
            position: absolute;
            border-radius: 50%;
            z-index: 1;
            pointer-events: none;
        }
        .deco--circle-1 {
            width: 280px; height: 280px;
            background: radial-gradient(circle, rgba(61,205,88,.18) 0%, transparent 70%);
            top: -80px; right: -80px;
        }
        .deco--circle-2 {
            width: 180px; height: 180px;
            background: radial-gradient(circle, rgba(61,205,88,.1) 0%, transparent 70%);
            bottom: 30px; left: -40px;
        }

        /* RIGHT — white form panel */
        .login-panel--right {
            background: #fff;
        }

        .login-panel--right .panel-inner {
            justify-content: center;
            gap: 1.25rem;
        }

        .se-logo {
            width: 110px;
            height: auto;
            margin-bottom: .5rem;
        }

        .login-heading {}
        .greeting {
            font-family: var(--font-main);
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--se-dark);
            line-height: 1.2;
        }
        .sub-greeting {
            font-size: .85rem;
            color: var(--se-muted);
            margin-top: .3rem;
        }

        /* ── Alert box ────────────────────────────────────────────── */
        .alert-box {
            padding: .75rem 1rem;
            border-radius: 8px;
            font-size: .84rem;
            line-height: 1.45;
        }
        .alert-box--danger {
            background: #fff2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
        }

        /* ── SESA Login Button ────────────────────────────────────── */
        .btn-sesa {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: .85rem 1.5rem;
            background: linear-gradient(135deg, var(--se-green) 0%, var(--se-green-dk) 100%);
            color: #fff;
            font-family: var(--font-main);
            font-size: .92rem;
            font-weight: 600;
            border: none;
            border-radius: var(--radius-btn);
            cursor: pointer;
            transition: transform .2s, box-shadow .2s, filter .2s;
            box-shadow: 0 4px 14px rgba(61,205,88,.35);
        }
        .btn-sesa:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(61,205,88,.45);
            filter: brightness(1.05);
        }
        .btn-sesa:active {
            transform: translateY(0);
        }

        .login-help {
            font-size: .78rem;
            color: var(--se-muted);
            text-align: center;
        }
        .login-help a {
            color: var(--se-green-dk);
            text-decoration: none;
            font-weight: 500;
        }
        .login-help a:hover { text-decoration: underline; }

        /* ── Modal ────────────────────────────────────────────────── */
        .login-modal {
            border: none;
            border-radius: 16px;
            overflow: hidden;
        }

        .login-modal .modal-header {
            background: var(--se-dark);
            color: #fff;
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: none;
        }

        .login-modal .modal-title {
            font-family: var(--font-main);
            font-size: .95rem;
            font-weight: 600;
        }

        .btn-close-modal {
            background: none;
            border: none;
            color: rgba(255,255,255,.6);
            cursor: pointer;
            font-size: 1rem;
            line-height: 1;
            padding: .25rem;
            transition: color .15s;
        }
        .btn-close-modal:hover { color: #fff; }

        .login-modal .modal-body {
            padding: 1.75rem 1.5rem;
        }

        /* Form fields */
        .field-group { margin-bottom: 1.1rem; }

        .field-label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: var(--se-dark);
            margin-bottom: .4rem;
            letter-spacing: .03em;
            text-transform: uppercase;
        }

        .field-input {
            width: 100%;
            padding: .65rem .9rem;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-size: .9rem;
            font-family: var(--font-body);
            color: var(--se-dark);
            background: var(--se-light);
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }
        .field-input:focus {
            border-color: var(--se-green);
            box-shadow: 0 0 0 3px rgba(61,205,88,.15);
            background: #fff;
        }
        .field-input::placeholder { color: #b0bac6; }

        /* Modal action buttons */
        .modal-actions {
            display: flex;
            gap: .75rem;
            margin-top: 1.5rem;
        }
        .btn-submit {
            flex: 2;
            padding: .65rem;
            border: none;
            border-radius: var(--radius-btn);
            background: linear-gradient(135deg, var(--se-green) 0%, var(--se-green-dk) 100%);
            color: #fff;
            font-family: var(--font-main);
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform .15s, box-shadow .15s, filter .15s;
            box-shadow: 0 3px 10px rgba(61,205,88,.3);
        }
        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 14px rgba(61,205,88,.4);
            filter: brightness(1.05);
        }
        .btn-submit:disabled {
            opacity: .7;
            cursor: not-allowed;
            transform: none;
        }

        /* ── Responsive ───────────────────────────────────────────── */
        @@media (max-width: 650px) {
            .login-card {
                grid-template-columns: 1fr;
            }

            .login-panel--left .panel-inner {
                padding: 2.5rem 2rem 2rem;
                flex-direction: row;
                align-items: center;
                gap: 1rem;
                min-height: unset;
            }

            .brand-logo    { width: 45%; max-width: 150px; }
            .brand-tagline { margin-top: 0; padding-top: 0; }
            .badge-version { display: none; }
            .tagline-title { font-size: .9rem; }
            .tagline-sub   { font-size: .72rem; }
            .deco          { display: none; }

            .login-panel--right .panel-inner {
                padding: 2rem 1.75rem 2.5rem;
            }

            .greeting { font-size: 1.35rem; }
        }
    </style>

</body>
</html>
