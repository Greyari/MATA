        function GenerateDate() {
            var deferred = $.Deferred();

            $.ajax({
                url: "@Url.Action("GetDateSO", "MAT")",
                type: 'get',
                dataType: 'json',
                success: function (response) {
                    if (response && response.fromDate && response.currentDate) {
                        $('#date_from').val(response.fromDate);
                        $('#date_to').val(response.currentDate);
                        deferred.resolve(); 
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', 'text': ('Week is not available'), 'type': 'error' });
                        deferred.reject(); 
                    }
                },
                error: function () {
                    Swal.fire({ icon: 'error', title: 'Error', 'text': ('Unable to read week'), 'type': 'error' });
                    deferred.reject();
                }
            });

            return deferred.promise();
        }

        function validateAndOpenModal(order_id) {
            $('#spinner_loading').show();
        
            $.ajax({
                url: '@Url.Action("ValidateAndGetAction", "MAT")',
                type: 'GET',
                data: {
                    order_id: order_id
                },
                success: function(response) {
                    $('#spinner_loading').hide();
        
                    if (response.success) {
                        switch (response.actionToRun) {
                            case 'actionOwner':
                                actionOwner(order_id);
                                break;
                            case 'actionOwnerClarify':
                                actionOwner2(order_id);
                                break;
                            case 'actionAssigned':
                                actionAssigned(order_id);
                                break;
                            case 'actionValidator':
                                actionValidator(order_id);
                                break;
                            case 'actionDetailABN':
                                actionDetailABN(order_id);
                                break;
                            default:
                                console.log('Action not permitted or not found.');
                                break;
                        }
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Access denied',
                            text: response.message
                        });
                    }
                },
                error: function(xhr, status, error) {
                    $('#spinner_loading').hide();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Gagal memvalidasi status. ' + error
                    });
                }
            });
        }

        function getTable() {
            var date_from = $('#date_from').val();
            var date_to = $('#date_to').val();
            var facility_id = $('#filter_facility').val();

            $('#ABNTableContainer').hide();
            $('#spinner_loading').show();

            if (!date_from || !date_to || !facility_id) {
                console.warn("Filter data belum lengkap. Menunggu filter terisi.");
                $('#spinner_loading').hide(); 
                return;
            }

            if ($.fn.DataTable.isDataTable('#tbl_details_filter')) {
                $('#tbl_details_filter').DataTable().clear().destroy();
            }

            $.ajax({
                url: '@Url.Action("GetABN", "MAT")',
                type: 'GET',
                data: {
                    date_from: date_from,
                    date_to: date_to,
                    facility_id: facility_id
                },
                success: function (result) {
                    $('#ABNTableContainer').html(result);
                    $('#ABNTableContainer').show();

                    $('#tbl_details_filter').DataTable({
                        responsive: false,
                        autoWidth: false,
                        searching: true,
                        paging: true,
                        ordering: true,
                        info: true,
                        order: [[0, 'asc']]
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Gagal memuat partial view:", status, error);
                    $('#ABNTableContainer').html('<div class="alert alert-danger">Error loading data. Please try again.</div>');
                    $('#ABNTableContainer').show();
                },
                complete: function() {
                    $('#spinner_loading').hide();
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const preview = document.getElementById('action_img_preview_add');
            const defaultImage = '../assets/notavailable.png';
            var imgpath = document.getElementById('action_file_input_add');

            if (preview) {
                preview.src = defaultImage;
                preview.style.display = 'none'; 
            }

            if (imgpath) {
                imgpath.addEventListener('change', function () {
                    if (this.files && this.files[0]) {
                        var file = this.files[0];
                        var imgsize = Math.ceil(file.size / 1024 / 1024);

                        if (imgsize > 1) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'The selected image size is ' + imgsize + ' MB. Please choose another photo that has size less than 1 MB'
                            });
                            this.value = '';
           
                            if(preview) preview.style.display = 'none';
                            document.getElementById('action_file_name_display_add').textContent = 'No file chosen';
                            return false;
                        }
                        else {
                            const reader = new FileReader();
                            document.getElementById('action_file_name_display_add').textContent = file.name;
                           
                            document.getElementById('action_file_reset_btn_add').style.display = 'inline';

                            reader.addEventListener('load', function () {
                                if(preview) {
                                    preview.src = this.result;
                                    preview.style.display = 'block';
                                }
                            });

                            reader.readAsDataURL(file);
                        }
                    } else {
                        if(preview) preview.style.display = 'none';
                    }
                });
            }

            const resetBtn = document.getElementById('action_file_reset_btn_add');
            if(resetBtn) {
                resetBtn.addEventListener('click', function() {
                    document.getElementById('action_file_input_add').value = '';
                    document.getElementById('action_file_name_display_add').textContent = 'No file chosen';
                    if(preview) {
                        document.getElementById('action_img_preview_add').src = defaultImage;
                        document.getElementById('action_img_preview_add').style.display = 'none';
                    }
                    this.style.display = 'none';
                });
            }
        });
        
        
