@section Scripts {
    <script>
        const CURRENT_USER_SESA = '@current_sesa';
        const CURRENT_USER_NAME = '@current_name';

        function fetchActionOwner(facilityId, tagId) {
            return $.ajax({
                url: '@Url.Action("GetActionOwner", "MAT")',
                type: 'GET',
                dataType: 'json',
                data: {
                    FacilityId: facilityId,
                    TagId: tagId
                }
            });
        }

        function updateActionOwnerFields(fixedByType) {
            var $actionOwnerDisplay = $('#action_owner_display');
            var $actionOwnerSesaHidden = $('#action_owner_sesa_hidden');
            var $validatedByContainer = $('#validated_by_container');
            var $validatedByDisplay = $('#validated_by_display');
            var $validatedBySesaHidden = $('#validated_by_sesa_hidden');

            $actionOwnerDisplay.val('');
            $actionOwnerSesaHidden.val('');
            $validatedByContainer.slideUp(200);
            $validatedByDisplay.val('');
            $validatedBySesaHidden.val('');

            if (fixedByType === '--- Select ---') {
                return;
            }

            var facilityId = $('#facility_id').val();
            var tagId = $('#tpm_tag').val();

            if (fixedByType === 'Fixed by myself') {
                $actionOwnerDisplay.val(CURRENT_USER_NAME);
                $actionOwnerSesaHidden.val(CURRENT_USER_SESA);

                if (facilityId && tagId && facilityId !== '--- Select Facility ---' && tagId !== '--- Select TPM Tag ---') {
                    fetchActionOwner(facilityId, tagId)
                        .done(function(response) {
                            if (response && response.name) {
                                $validatedByDisplay.val(response.name);
                                $validatedBySesaHidden.val(response.sesaId);
                                $validatedByContainer.slideDown(200);
                            } else {
                                $validatedByDisplay.val('Validator (Owner) not found');
                                $validatedBySesaHidden.val('');
                                $validatedByContainer.slideDown(200);
                            }
                        })
                        .fail(function() {
                            $validatedByDisplay.val('Error loading validator (owner)');
                            $validatedBySesaHidden.val('');
                            $validatedByContainer.slideDown(200);
                        });
                } else {
                     $validatedByDisplay.val('Select Tag/Facility first');
                     $validatedByContainer.slideDown(200);
                }

            } else if (fixedByType === 'Action owner') {
                $validatedByContainer.slideUp(200);

                if (facilityId && tagId && facilityId !== '--- Select Facility ---' && tagId !== '--- Select TPM Tag ---') {
                    fetchActionOwner(facilityId, tagId)
                        .done(function(response) {
                            if (response && response.name) {
                                $actionOwnerDisplay.val(response.name);
                                $actionOwnerSesaHidden.val(response.sesaId);
                            } else {
                                $actionOwnerDisplay.val('Owner not found');
                                $actionOwnerSesaHidden.val('');
                            }
                        })
                        .fail(function() {
                            $actionOwnerDisplay.val('Error loading owner');
                            $actionOwnerSesaHidden.val('');
                        });
                }
            }
        }

        const toggleArrows = document.querySelectorAll('.toggleArrow');
        toggleArrows.forEach(toggleArrow => {
            const cardBody = toggleArrow.parentElement.nextElementSibling;
            if (cardBody) {
                cardBody.style.display = 'none';
                toggleArrow.innerHTML = '&#9650;';
            }
            toggleArrow.addEventListener('click', () => {
                if (!cardBody) return;
                const isCollapsed = cardBody.style.display === 'none';
                if (isCollapsed) {
                    cardBody.style.display = 'block';
                    toggleArrow.innerHTML = '&#9660;';
                } else {
                    cardBody.style.display = 'none';
                    toggleArrow.innerHTML = '&#9650;';
                }
            });
        });
        function zoomAllImage(image, picture, findings, corrective) {
            var alt_img = '@Url.Content("~/assets/notavailable.png")';
            var basePath = '@Url.Content("~/upload/img/abn/")';
            $("#show_all_picture").modal("show");
            $("#img_before").attr("src", basePath + picture);
            $("#img_after").attr("src", basePath + image);
            $("#img_before").attr("onerror", `this.onerror=null; this.src='${alt_img}';`);
            $("#img_after").attr("onerror", `this.onerror=null; this.src='${alt_img}';`);
            $('#remark_findings').val(findings);
            $('#remark_countermeasure').val(corrective);
        }
        function viewPdf(attachment_file) {
            var basePath = '@Url.Content("~/upload/img/abn/pdf/")';
            $("#view_pdf").modal("show");
            $("#pdfViewer").attr("src", basePath + attachment_file);
        }
        function setMaxDate() {
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0'); 
            const day = String(today.getDate()).padStart(2, '0'); 
            const maxDate = `${year}-${month}-${day}`;
            const dateInput = document.getElementById('date_completed');
            if (dateInput) {
                dateInput.max = maxDate;
            }
            const dateInput2 = document.getElementById('date_find');
            if (dateInput2) {
                dateInput2.max = maxDate;
            }
        }
        function zoomFindingsPicture() {
            var alt_img = '@Url.Content("~/assets/notavailable.png")';
            $("#show_findings_picture").modal("show");
            $(".display_file_img_findings").attr("onerror", `this.onerror=null; this.src='${alt_img}';`);
        }
        function zoomActionPicture() {
            var alt_img = '@Url.Content("~/assets/notavailable.png")';
            $("#show_action_picture").modal("show");
            $(".display_file_img_action").attr("onerror", `this.onerror=null; this.src='${alt_img}';`);
        }
        function findings_picture_close() {
            $("#show_findings_picture").modal("hide");
        }
        function action_picture_close() {
            $("#show_action_picture").modal("hide");
        }
        function all_picture_close() {
            $("#show_all_picture").modal("hide");
        }
        function pdf_close() {
            $("#view_pdf").modal("hide");
        }
        function getOwnerName() {
            var facilityId = $('#facility_id').val();
            var tagId = $('#tpm_tag').val();

            $('#owner_name').val('');

            if (facilityId && tagId && facilityId !== '--- Select Facility ---' && tagId !== '--- Select TPM Tag ---') {

                $.ajax({
                    url: '@Url.Action("GetActionOwner", "MAT")',
                    type: 'GET',
                    dataType: 'json',
                    data: {
                        FacilityId: facilityId,
                        TagId: tagId
                    },
                    success: function(response) {
                        if (response && response.name) {
                            $('#owner_name').val(response.name);
                        } else {
                            $('#owner_name').val('Owner not found');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error("AJAX Error:", status, error);
                        $('#owner_name').val('Error loading owner');
                    }
                });
            }
        }
        function loadAssignedAction(amChecklistValue, facilityId) {
            var $assignedAction = $('#assigned_action');

            $assignedAction.empty().append('<option value="">--- Loading ---</option>');

            if (amChecklistValue && amChecklistValue !== '--- Select ---') {
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("GetAssignedAction")",
                    data: { amChecklist: amChecklistValue, facilityId: facilityId },
                    dataType: "json",
                    success: function(data) {
                        $assignedAction.empty();                                  
                        $.each(data, function(i, item) {
                            $assignedAction.append($('<option>', {
                                value: item.code,
                                text: item.name
                            }));
                        });

                        if ($assignedAction.hasClass('select2')) {
                            $assignedAction.trigger('change');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error("Error loading Assigned Action:", error);
                        $assignedAction.empty().append('<option value="">--- Error Loading ---</option>');
                        if ($assignedAction.hasClass('select2')) {
                            $assignedAction.trigger('change');
                        }
                    }
                });
            } else {
                
                $assignedAction.empty().append('<option value="">Select AM Checklist</option>');
                if ($assignedAction.hasClass('select2')) {
                    $assignedAction.trigger('change');
                }
            }
        }

            $('#am_checklist_fixed_add').on('change', function() {
            var selectedValue = $(this).val();

            const $inputCorrective = $('#input_corrective_action_add');
            const $targetDate = $('#date_target_add');
            const $pdfFile = $('#pdfFile_add');
            const $actionPicInput = $('#action_file_input_add');

            const $actionFieldsContainers = $('.fixed-myself-fields.hideable-action-fields');

            const $actionPicCol = $actionPicInput.closest('.fixed-myself-fields');
            const $actionPrevCol = $('#action_img_preview_add').closest('.fixed-myself-fields');
            const $picPreviewContainers = $('.fixed-myself-fields.mt-3');


            if (selectedValue === 'N') {
             
                $actionFieldsContainers.slideDown(200);
                $picPreviewContainers.slideDown(200);

                $inputCorrective.prop('required', true);
                $targetDate.prop('required', true);
                $actionPicInput.prop('required', true);

            } else {
          
                $actionFieldsContainers.slideUp(200);
                $picPreviewContainers.slideUp(200);

                $inputCorrective.val('').prop('required', false);
                $targetDate.val('').prop('required', false);
                $pdfFile.val('').prop('required', false);
                $actionPicInput.val('').prop('required', false);

                $('#action_file_name_display_add').text('No file chosen');
                $('#action_file_reset_btn_add').hide();
                $('#action_img_preview_add').hide();
            }
        });

        $('#am_checklist_fixed_add').trigger('change');

        $(document).ready(function() {
            $('#fixed_myself').on('change', function() {
            var selectedValue = $(this).val();
            var $fields = $('.fixed-myself-fields');

            if (selectedValue === 'Fixed by myself') {
                $fields.slideDown(200);

                $('#am_checklist_fixed_add').trigger('change');

                $('#abn_type_add').prop('required', true);
                $('#abn_happen_add').prop('required', true);
                $('#abn_rootcause_add').prop('required', true);
                $('#input_root_add').prop('required', true);
                $('#input_corrective_action_add').prop('required', true);
                $('#action_file_input_add').prop('required', true);
                $('#date_target_add').prop('required', true); 

        
                var abnType = $('#abn_type_add').val();
                if (abnType === 'SOC' || abnType === 'HTA') {
                    $('.machine_input_container_add').slideDown(200);
                    $('#input_machine_add').prop('required', true);
                } else {
                    $('.machine_input_container_add').slideUp(200);
                    $('#input_machine_add').prop('required', false);
                }

            } else {
                $fields.slideUp(200);
                $fields.find('select, textarea, input[type="file"], input[type="date"], input[type="text"]').prop('required', false).val('');
                $('#abn_type_add').val('--- Select ---').trigger('change');
                $('#abn_happen_add').val('--- Select ---').trigger('change');
                $('#abn_rootcause_add').val('--- Select ---').trigger('change');
                $('.machine_input_container_add').hide();
            }
        });

            $('#abn_type_add').on('change', function() {
                var selectedType = $(this).val();
                var $machineContainer = $('.machine_input_container_add');
                var specialTypes = ['SOC', 'HTA'];
                if ($('#fixed_myself').val() === 'Fixed by myself') {
                    if (specialTypes.includes(selectedType)) {
                        $machineContainer.slideDown(200);
                        $('#input_machine_add').prop('required', true);
                    } else {
                        $machineContainer.slideUp(200);
                        $('#input_machine_add').prop('required', false);
                    }
                }
            });

            $('#assigned_action').empty().append('<option value="">Select AM Checklist</option>');

            $('#am_checklist').on('change', function() {
                var selectedValue = $(this).val();
                var facilityId = $('#hidden_facility_id').val();
                loadAssignedAction(selectedValue, facilityId);

                var $Container = $('.yes');
                var requiredTypes = ['N'];

                if (requiredTypes.includes(selectedValue)) {
                    $Container.slideDown(200);

                    $('#input_corrective_action').prop('required', true);
                    $('#date_target').prop('required', true);
                    $('#action_file_input_completed').prop('required', true);
                } else {
                    $Container.slideUp(200);

                    $('#date_completed').val('').prop('required', false);
                    $('#date_target').prop('required', false);
                    $('#action_file_input_completed').val('').prop('required', false);                
                }
            });

        });

            $(document).ready(function() {
                $('#status').on('change', function() {
                    var selectedType = $(this).val();
                    var $Container = $('.date_completed_container');
                    var requiredTypes = ['Closed'];

                    if (requiredTypes.includes(selectedType)) {
                        $Container.slideDown(200); 
                        $('#date_completed').prop('required', true);
                    } else {
                        $Container.slideUp(200); 

                        $('#date_completed').val('').prop('required', false);
                    }
                });

                const urlParams = new URLSearchParams(window.location.search);
                const order_id = urlParams.get('order_id');
                if (order_id) {
                    validateAndOpenModal(order_id);
                }
            // $('#abn_type').on('change', function() {
            //     var selectedType = $(this).val();

            //     var $Container = $('.machine_input_container');

            //     var requiredTypes = ['SOC', 'HTA'];

            //     if (requiredTypes.includes(selectedType)) {
            //         $Container.slideDown(200);

            //         $('#input_machine').prop('required', true);
            //     } else {
            //         $Container.slideUp(200);

            //         $('#input_machine').val('').prop('required', false);
            //     }
            // });

            $('#abn_type').on('change', function() {
                var selectedType = $(this).val();
            
                var $machineContainer = $('.machine_input_container');
                var $hideableFields = $('.abn-hideable-field');
            
                var specialTypes = ['SOC', 'HTA'];
                var srpType = 'SRP';
            
                if (selectedType === srpType) {
                    $hideableFields.slideUp(200);
            
                    $hideableFields.find('select, input, textarea').prop('required', false);
            
                    $machineContainer.hide();
                    $('#input_machine').prop('required', false);
            
                } else {
                    $hideableFields.slideDown(200);
            
                    if (specialTypes.includes(selectedType)) {
                        $machineContainer.slideDown(200);
                        $('#input_machine').prop('required', true);
                    } else {
                        $machineContainer.slideUp(200);
                        $('#input_machine').prop('required', false);
                    }
                }
            });
            
            $('#tpm_tag').on('change', function() {
                var selectedType = $(this).val();
                var $selectedOption = $(this).find('option:selected');
                var selectedName = $selectedOption.data('name');

                var $Container = $('#sesa_op_container');

                var requiredTypes = ['White'];

                $('#tag_id').val(selectedName);

                var colorMap = {
                    'White': 'white', 
                    'Green': 'green',
                    'Red': 'red',
                    'Yellow': 'yellow'
                };
                
                var selectedColor = colorMap[selectedType];
                var textColor = (selectedType === 'White' || selectedType === 'Yellow') ? 'black' : 'white';

                if (selectedColor) {
                    $('#tag_id').css({
                        'background-color': selectedColor,
                        'color': textColor,
                        'font-weight': 'bold'
                    });
                } else {
                    $('#tag_id').css({
                        'background-color': '',
                        'color': 'black',
                        'font-weight': 'normal'
                    });
                }

                if (requiredTypes.includes(selectedType)) {
                    $Container.slideDown(200);

                    $('#sesa_op').prop('required', true);
                } else {
                    $Container.slideUp(200);

                    $('#sesa_op').prop('required', false);
