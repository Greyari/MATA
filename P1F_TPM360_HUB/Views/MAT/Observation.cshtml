        $("#create_Data").click(function () {

        var date_find = $('#date_find').val();
        var facility_id = $('#facility_id').val();
        var line = $('#line').val();
        var station = $('#station').val();
        var tpm_tag = $('#tpm_tag').val();
        var sesa_op = $('#sesa_op').val();
        var finding = $('#finding').val();
        var fileInput = $('#finding_file_input')[0].files[0];
        var fixed_myself = $('#fixed_myself').val();

        var abn_type = $('#abn_type_add').val(); 
        var abn_happen = $('#abn_happen_add').val();
        var abn_rootcause = $('#abn_rootcause_add').val();
        var input_root = $('#input_root_add').val();
        var input_machine = $('#input_machine_add').val();
        var input_corrective_action = $('#input_corrective_action_add').val();
        var fileInputAction = $('#action_file_input_add')[0].files[0];
        var date_target = $('#date_target_add').val();
        var am_checklist_add = $('#am_checklist_fixed_add').val();
        var action_owner_sesa = $('#action_owner_sesa_hidden').val();
        var validated_by_sesa = $('#validated_by_sesa_hidden').val();
        var fileInputPdf = $('#pdfFile_add')[0].files[0];

        if (fixed_myself === 'Fixed by myself') {
            if (abn_type === '--- Select ---' || !abn_happen || abn_happen === '--- Select ---' || abn_rootcause === '--- Select ---' || !input_root || !input_corrective_action || !fileInputAction || !date_target) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Please Fill in All the Action Owner/Fixed by myself requirements!'
                });
                return;
            }

            if ((abn_type === 'SOC' || abn_type === 'HTA') && !input_machine) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Please fill in Machine Major/Sub Part!'
                });
                return;
            }
        }

        if (!date_find || !facility_id || !line || !station || !tpm_tag || !finding || !fileInput) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Please Fill in All the required Finding fields first!'
            });
            return; 
        }

        var am_checklist = (fixed_myself === 'Fixed by myself') ? 'N' : null;
        var assigned_action = (fixed_myself === 'Fixed by myself') ? 'SELF' : null;
        var status_for_action = (fixed_myself === 'Fixed by myself') ? 'Open' : 'Closed';
        var date_completed = (fixed_myself === 'Fixed by myself') ? date_target : null;

        if (fileInput) {

            const reader = new FileReader();
            reader.onload = function (event) {
                const image = new Image();
                image.src = event.target.result;

                image.onload = function () {
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    canvas.width = image.width;
                    canvas.height = image.height;
                    ctx.drawImage(image, 0, 0);

                    canvas.toBlob(function (blob) {
                        const formData = new FormData();
                        formData.append('file', blob, fileInput.name);
                        if (fileInputPdf) {
                            formData.append('FormFileAdd', fileInputPdf);
                        }
                        formData.append('date_find', date_find);
                        formData.append('facility_id', facility_id);
                        formData.append('line', line);
                        formData.append('station', station);
                        formData.append('tpm_tag', tpm_tag);
                        formData.append('sesa_op', sesa_op);
                        formData.append('finding', finding);

                        formData.append('fixed_myself', fixed_myself);
                        formData.append('abn_type', abn_type);
                        formData.append('abn_happen', abn_happen);
                        formData.append('abn_rootcause', abn_rootcause);
                        formData.append('input_root', input_root);
                        formData.append('input_machine', input_machine); 
                        formData.append('input_corrective_action', input_corrective_action);
                        formData.append('validated_by_sesa', validated_by_sesa); // Harus ditambahkan
                        formData.append('action_owner_sesa', action_owner_sesa);

                        formData.append('am_checklist', am_checklist);
                        formData.append('assigned_action', assigned_action);
                        formData.append('status_for_action', status_for_action);
                        formData.append('date_completed', date_completed);
                        formData.append('date_target', date_target); 

                        if (fileInputAction) {
                            formData.append('file_action', fileInputAction);
                        } else {
                            formData.append('file_action', null);
                        }

                        Swal.fire({
                            title: 'Add New Safety Observation?',
                            text: "Are you sure for this action?",
                            icon: 'warning',
                            showCancelButton: true,
