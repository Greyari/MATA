            }

            function getDetail1Param(v_a_l_u_e, controlTarget) {
                var facilityVal = $('#select_filter_2').val() || [];
                var lineVal = $('#select_filter_3').val() || [];
                var stationVal = $('#select_filter_4').val() || [];

                var range = $('input[name="range-options"]:checked').val();
                var facility = facilityVal.join(',');
                var line = lineVal.join(',');
                var station = stationVal.join(',');
                var date_from = $('#date_from').val();
                var date_to = $('#date_to').val();

                $('#TableContainer').hide();

                $.ajax({
                    type: "POST",
                    cache: false,
                    url: controlTarget,
                    data: {facility: facility, line:line, station:station, date_from: date_from, date_to: date_to, range: range, value: v_a_l_u_e},
                    success: function (result) {
                        $('#sub_title').text('(' + v_a_l_u_e + ')');
                        // 1. Hancurkan DataTables lama jika ada
                        if (detailTableInstance) {
                            detailTableInstance.destroy();
                        }

                        // 2. Masukkan HTML baru ke <tbody>
                        $('#TableContainer').html(result);
                        $('#TableContainer').show();

                        // 3. Inisialisasi DataTables baru
                        detailTableInstance = $('#tbl_details_filter2').DataTable({
                            responsive: true,
                            autoWidth: false,
                            searching: true,
                            paging: true,
                            ordering: true,
                            info: true,
                            order: [[1, 'asc']] // Urutkan berdasarkan kolom kedua (SESA ID)
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("Gagal memuat partial view:", status, error);
                        $('#TableContainer').html('<div class="alert alert-danger">Error loading data. Please try again.</div>');
                        $('#TableContainer').show();
                    },
                    complete: function() {
                        //$('#spinner_loading').hide();
                    }
                });
            }

            function getDetail2Param(v_a_l_u_e, type, controlTarget) {
                var facilityVal = $('#select_filter_2').val() || [];
                var lineVal = $('#select_filter_3').val() || [];
                var stationVal = $('#select_filter_4').val() || [];

                var range = $('input[name="range-options"]:checked').val();
                var facility = facilityVal.join(',');
                var line = lineVal.join(',');
                var station = stationVal.join(',');
                var date_from = $('#date_from').val();
                var date_to = $('#date_to').val();

                $('#TableContainer').hide();

                $.ajax({
                    type: "POST",
                    cache: false,
                    url: controlTarget,
                    data: {facility: facility, line:line, station:station, date_from: date_from, date_to: date_to, range: range, value: v_a_l_u_e, type: type},
                    success: function (result) {
                        $('#sub_title').text('(' + v_a_l_u_e + ' & ' + type + ')');
                        if (detailTableInstance) {
                            detailTableInstance.destroy();
                        }

                        $('#TableContainer').html(result);
                        $('#TableContainer').show();

                        detailTableInstance = $('#tbl_details_filter2').DataTable({
                            responsive: true,
                            autoWidth: false,
                            searching: true,
                            paging: true,
                            ordering: true,
                            info: true,
                            order: [[1, 'asc']]
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("Gagal memuat partial view:", status, error);
                        $('#TableContainer').html('<div class="alert alert-danger">Error loading data. Please try again.</div>');
                        $('#TableContainer').show();
                    },
                    complete: function() {
                        //$('#spinner_loading').hide();
                    }
                });
            }

    </script>
