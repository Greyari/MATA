            function getOPLsPerSite() {
                var facilityVal = $('#select_filter_2').val() || [];
                var lineVal = $('#select_filter_3').val() || [];
                var stationVal = $('#select_filter_4').val() || [];
                var range = $('input[name="range-options"]:checked').val();

                var facility = facilityVal.join(',');
                var line = lineVal.join(',');
                var station = stationVal.join(',');

                var date_from = $('#date_from').val();
                var date_to = $('#date_to').val();

                const ctx = document.getElementById('opls_per_site');

                if (oplsPerSiteChartInstance) {
                    oplsPerSiteChartInstance.destroy();
                    oplsPerSiteChartInstance = null;
                }

                $.ajax({
                    type: "POST",
                    cache: false,
                    url: "@Url.Action("GET_OPLS_PER_SITE", "MAT")",
                    data: {
                        facility: facility,
                        line: line,
                        station: station,
                        date_from: date_from,
                        date_to: date_to,
                        range: range
                    },
                    success: function(data) {
                        console.log("tadaaa")
                        let labels = [];
                        let dataFindings = [];

                        // Siapkan array warna agar setiap potongan doughnut berbeda warna
                        // Anda bisa menambah/mengganti kode warna hex di sini
                        let backgroundColors = [
                            '#dc3545', '#0d6efd', '#198754', '#ffc107', '#0dcaf0',
                            '#6610f2', '#fd7e14', '#20c997', '#e83e8c', '#6f42c1'
                        ];

                        let dynamicColors = [];

                        if (data && data.length > 0) {
                            data.forEach((item, index) => {
                                labels.push(item.Facility);
                                dataFindings.push(parseFloat(item.Closed) || 0);

                                // Ambil warna dari array, gunakan modulus (%) agar warna berulang jika data > jumlah warna
                                dynamicColors.push(backgroundColors[index % backgroundColors.length]);
                            });
                        }

                        oplsPerSiteChartInstance = new Chart(ctx, {
                            type: 'doughnut', // UBAH TIPE DI SINI
                            data: {
                                labels: labels,
                                datasets: [
                                    {
                                        label: 'Findings',
                                        data: dataFindings,
                                        backgroundColor: dynamicColors, // Gunakan array warna
                                        borderColor: '#ffffff', // Border putih agar pemisah antar slice terlihat jelas
                                        borderWidth: 2,
                                        hoverOffset: 4
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                // scales dihapus karena doughnut chart tidak butuh sumbu X/Y
                                plugins: {
                                    legend: {
                                        display: true, // Tampilkan legend agar tahu warna X = Facility apa
                                        position: 'bottom', // Posisi legend (top, bottom, left, right)
                                        labels: {
                                            usePointStyle: true,
                                            padding: 20
                                        }
                                    },
                                    datalabels: {
                                        color: '#fff', // Warna text angka menjadi putih agar kontras
                                        anchor: 'center', // Posisi angka di tengah slice
                                        align: 'center',
                                        formatter: (value) => value > 0 ? value : '',
                                        font: {
                                            weight: 'bold',
                                            size: 18
                                        }
                                    },
                                    title: {
                                        display: false
                                    },
                                    tooltip: {
                                        callbacks: {
                                            label: function(context) {
                                                let label = context.label || '';
                                                if (label) {
                                                    label += ': ';
                                                }
                                                let value = context.raw;
                                                // Menghitung persentase (opsional, bagus untuk doughnut)
                                                let total = context.chart._metasets[context.datasetIndex].total;
                                                let percentage = Math.round((value / total) * 100) + '%';
                                                return label + value + ' (' + percentage + ')';
                                            }
                                        }
                                    }
                                },
                                onClick: (event, elements) => {
                                    //Pastikan pengguna mengklik sebuah elemen (bukan ruang kosong)
                                    if (elements.length > 0) {

                                        const index = elements[0].index;

                                        const label = oplsPerSiteChartInstance.data.labels[index];

                                        actionDetailOPLsPerSite(label);
                                    }
                                }
                            },
                            plugins: [ChartDataLabels]
                        });
                    },
                    error: function(xhr, status, error) {
                        console.error('Error fetching data:', error);
                    }
                });
            }

