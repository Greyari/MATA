@model (string Title, string Background)

<section
    class="d-flex align-items-center justify-content-center position-relative text-center"
    style="
        min-height:80px;
        background-image:linear-gradient(rgba(0,0,0,.5),rgba(0,0,0,.5)), url('@Model.Background');
        background-size:cover;
        background-position:center top;
        background-repeat:no-repeat;
        z-index:1000;
    ">

    <h3 class="text-white m-0 fw-bold">
        @Model.Title
    </h3>

</section>