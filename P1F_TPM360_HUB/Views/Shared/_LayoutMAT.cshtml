    <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/js/bootstrap-select.min.js"></script>
    <script>
        $(document).ready(function () {
            // Active link logic lama
            var currentUrl = window.location.pathname;
            $('ul.nav-sidebar a').each(function() {
                var href = $(this).attr('href');
                if (currentUrl === href) {
                    $(this).addClass('active');
                    $(this).closest('.nav-treeview').css('display', 'block').prev().addClass('active');
                    $(this).closest('.nav-item.has-treeview').addClass('menu-open');
                }
            });

            const $body = $('body');
            const $sidebar = $('.main-sidebar');
            const $img = $('#sidebar-brand-img');

            const imgOpen = '@Url.Content("~/assets/logo.png")';
            const imgClosed = '@Url.Content("~/assets/logos.png")';

            function updateSidebarLogo() {
                if ($body.hasClass('sidebar-collapse') && !$body.hasClass('sidebar-open')) {
                    $img.attr('src', imgClosed);
                    $img.css({'max-height': '25px', 'max-width': '40px'}); // Ukuran logo kecil
                } else {
                    $img.attr('src', imgOpen);
                    $img.css({'max-height': '35px', 'max-width': 'initial'}); // Ukuran logo normal
                }
            }

            updateSidebarLogo();

            $(document).on('click', '[data-widget="pushmenu"]', function (e) {
                e.preventDefault();
                setTimeout(updateSidebarLogo, 350);
            });

            $sidebar.on('mouseenter', function () {
                 if ($body.hasClass('sidebar-collapse')) {
                    $img.attr('src', imgOpen);
                    $img.css({'max-height': '35px', 'max-width': 'initial'});
                 }
            });

            $sidebar.on('mouseleave', function () {
                if ($body.hasClass('sidebar-collapse')) {
                    updateSidebarLogo();
                }
            });
        });

        // Function to convert number to 'K' format
        function number_to_k(n, precision = 2) {
            return (n / 1000).toFixed(precision) + 'K';
        }

        function showSessionExpirationModal() {
            Swal.fire({
                title: 'Session Expiration Notice',
                text: 'Your session is about to expire. Do you want to stay logged in or log out?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Stay Logged In',
                cancelButtonText: 'Log Out',
                reverseButtons: true,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("RefreshSession", "Login")',
                        method: 'POST',
                        success: function () {
                            location.reload();
                        },
                        error: function () {
                            console.log('Error refreshing session');
                        }
                    });
                } else if (result.dismiss === Swal.DismissReason.cancel) {
                    window.location.href = '@Url.Action("Logout", "Home")';
                }
            });
        }

        setTimeout(showSessionExpirationModal, 15 * 60 * 1000);
        $('body').on("click", function (e) {
            $(this).removeClass('sidebar-open');
        });

    </script>
    @RenderSection("Scripts", required: false)
</body>
