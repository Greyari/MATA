@using P1F_TPM360_HUB.Function
@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor
@{
    string url = ViewContext.HttpContext.Request.Path;
    string lastSegment = url.Split('/').Last();

    string user_level = User.FindFirst("P1F_TPM360_HUB_level")?.Value;
    string user_role = User.FindFirst("P1F_TPM360_HUB_role")?.Value;
    string sesa_id = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    string name = User.FindFirst("P1F_TPM360_HUB_name")?.Value;
    var userLevels = user_level?.Split(';') ?? new string[0];
    var userRoles = user_role?.Split(';') ?? new string[0];

}
@{
    var isChangePasswordPage = ViewContext.RouteData.Values["action"].ToString() == "ChangePassword";
}

