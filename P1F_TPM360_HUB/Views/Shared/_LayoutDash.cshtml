                        <li class="nav-item dropdown">
                            <a class="nav-link d-flex align-items-center" id="dropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"
                               style="cursor: pointer;">

                                <div class="d-flex flex-column align-items-end" style="font-weight:bold; color:white; font-size: 0.9em;">
                                    <span>@userName</span>
                                    <small>@sesa_id</small>
                                </div>

                                <img src="~/assets/header.png" alt="Header Icon" style="height: 40px; margin-left: 10px;">
                            </a>

                            <div class="dropdown-menu dropdown-menu-right">
                                <a class="dropdown-item" href="@Url.Action("Logout", "Home")">
                                    <i class="nav-icon fas fa-power-off"></i>&emsp;Logout
                                </a>
                            </div>
                        </li>
                    </ul>
