    <link href="~/lib/font-awesome-5/css/solid.css" rel="stylesheet" />

    <!-- Bootstrap 4 & DataTables -->
    <link rel="stylesheet" href="~/lib/bootstrap-4/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/DataTables-1.10.22/css/dataTables.bootstrap4.min.css" />
