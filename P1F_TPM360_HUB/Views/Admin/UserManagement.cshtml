@{
    Layout = "~/Views/Shared/_LayoutMAT.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Management - Bootstrap 5</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link href="~/lib/adminlte/dist/css/adminlte.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/css/bootstrap-select.min.css">

    <style>
        .modal-dialog {
            max-width: 90% !important;
        }

        .modal-header {
            background-color: #3dcd58;
            color: white;
        }

        .sticky-header th {
            position: sticky;
            top: 0;
            background-color: #3dcd58 !important;
            z-index: 10;
        }
    </style>
</head>

<body class="sidebar-mini layout-fixed layout-navbar-fixed sidebar-collapse">
    <div class="wrapper">
        
        <!-- HERO HEADER -->
        <partial name="_HeroHeader" model='("User Management", "/images/background/bgusermanagement.jpeg")' />

        <div class="content">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-lg-12 mt-3">
                        <div class="card">
                            <div class="card-body">

                                <div class="text-center mt-3 mb-4">
                                    <button class="btn btn-primary btn-sm" onclick="addData()">
                                        <i class="fa fa-plus"></i> Add User
                                    </button>
                                    <button class="btn btn-sm btn-danger" id="delete_select">
                                        <i class="fas fa-trash"></i> Delete Selected
                                    </button>
                                </div>

                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label class="fw-bold small">SESA ID</label>
                                        <select class="form-control" id="sesax"></select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="fw-bold small">Username</label>
                                        <select class="form-control" id="namex"></select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="fw-bold small">Level</label>
                                        <select class="selectpicker form-control" id="levelx" multiple data-live-search="true" data-actions-box="true">
                                            @foreach (var item in ViewBag.Levels)
                                            {
                                                <option value="@item.Code">@item.Code</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-3 d-flex align-items-end">
                                        <button id="btn_apply" name="btn_apply" class="btn btn-success btn-sm w-100 me-2"><i class="fa fa-search"></i> Apply</button>
                                        <button class="btn btn-sm btn-warning w-100" onclick="window.location.reload()"><i class="fa fa-history"></i> Reset</button>
                                    </div>
                                </div>

                                <div class="table-responsive mt-4">
                                    <table class="table table-sm table-striped border" id="tbl_details_filter">
                                        <thead>
                                            <tr class="text-center sticky-header">
                                                <th class="text-white"><input type="checkbox" id="checkAll" onClick="toggle(this)" /> Check All</th>
                                                <th class="text-white">SESA ID</th>
                                                <th class="text-white">Name</th>
                                                <th class="text-white">Level</th>
                                                <th class="text-white">Role</th>
                                                <th class="text-white">Email</th>
                                                <th class="text-white">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody id="table_details"></tbody>
                                    </table>
                                    <div id="spinner_loading" class="text-center mt-2" style="display:none;">
                                        <i class="fas fa-spinner fa-spin fa-2x"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="modal_edit" class="modal fade" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5><i class="fa fa-info-circle me-2"></i>Edit User</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="hidden" id="id" />
                            <label class="fw-bold small">SESA ID*</label>
                            <input type="text" id="sesa_id" class="form-control form-control-sm" />
                            <label class="fw-bold small mt-2">Name*</label>
                            <input type="text" id="name" class="form-control form-control-sm" />
                            <label class="fw-bold small mt-2">Email*</label>
                            <input type="text" id="email" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold small">Select Level</label>
                            <select class="form-control selectpicker" id="select_level" multiple data-live-search="true">
                                @foreach (var item in ViewBag.Levels)
                                {
                                    <option value="@item.Code">@item.Code</option>
                                }
                            </select>
                            <label class="fw-bold small mt-2">Select Role</label>
                            <select class="form-control selectpicker" id="edit_role" multiple data-live-search="true">
                                @foreach (var item in ViewBag.Roles)
                                {
                                    <option value="@item.Code">@item.Code</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="text-center mt-4">
                        <button class="btn btn-success px-5" onclick="verify_save()"><i class="fas fa-save"></i> Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="modal_add" class="modal fade" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5><i class="fa fa-plus-circle me-2"></i>Add User</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="fw-bold small">SESA ID*</label>
                            <input type="text" id="sesa_id2" class="form-control form-control-sm" />
                            <label class="fw-bold small mt-2">Name*</label>
                            <input type="text" id="name2" class="form-control form-control-sm" />
                            <label class="fw-bold small mt-2">Password*</label>
                            <input type="password" id="password" class="form-control form-control-sm" />
                            <label class="fw-bold small mt-2">Email*</label>
                            <input type="text" id="email2" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold small">Select Level</label>
                            <select class="form-control selectpicker" id="select_levelx" multiple data-live-search="true">
                                @foreach (var item in ViewBag.Levels)
                                {
                                    <option value="@item.Code">@item.Code</option>
                                }
                            </select>
                            <label class="fw-bold small mt-2">Select Role</label>
                            <select class="form-control selectpicker" id="select_rolex" multiple data-live-search="true">
                                @foreach (var item in ViewBag.Roles)
                                {
                                    <option value="@item.Code">@item.Code</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="text-center mt-4">
                        <button class="btn btn-success px-5" id="create_Data"><i class="fas fa-pen"></i> Submit User</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-select/1.14.0-beta2/js/bootstrap-select.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/js/bootstrap-select.min.js"></script>

    @section Scripts {
        <script>
            let isSearch = false;

            function toggle(source) {
                $(".select_item").prop('checked', source.checked);
            }

            $(document).ready(function () {
                // 1. Inisialisasi Selectpicker Dasar
                // $('.selectpicker').selectpicker({
                //     container: 'body',
                //     noneSelectedText: 'Please Select'
                // });

                // 2. REFRESH SELECTPICKER DI MODAL (PENTING UNTUK BS5)
                // $('#modal_add, #modal_edit').on('shown.bs.modal', function () {
                //     $(this).find('.selectpicker').selectpicker('destroy').selectpicker({
                //         container: 'body',
                //         liveSearch: true,
                //         width: '100%'
                //     });
                // });

                // 3. Select2 Config
                $('#sesax, #namex').select2({
                    theme: 'bootstrap-5',
                    width: '100%',
                    allowClear: true,
                    ajax: {
                        url: (params) => params.id === 'sesax' ? "@Url.Action("GetUserSesa0")" : "@Url.Action("GetUserName0")",
                        url: function() { return $(this).attr('id') === 'sesax' ? "@Url.Action("GetUserSesa0")" : "@Url.Action("GetUserName0")" },
                        data: (params) => ({ family: params.term }),
                        processResults: (data) => ({ results: data.items })
                    }
                });

                // Auto apply
                setTimeout(() => { $('button[name=btn_apply]').click(); }, 500);
            });

            // ACTION APPLY FILTER

            $('button[name=btn_apply]').click(function () {
                var sesa_id = $("#sesax").val();
                var level = ($("#levelx").val() || []).join(';');
                var name = $("#namex").val() || "";

                $("#table_details").html('');
                var table = $("#table_details");
                var table1 = $("#tbl_details_filter");

                $('#spinner_loading').show();

                $.ajax({
                    url: "@Url.Action("GETUSER")",
                    type: "POST",
                    data: {
                        sesa_id: sesa_id,
                        level: level,
                        name: name
                    },
                    success: function (data) {
                        if (!isSearch)
                            isSearch = true;
                        else
                            table1.DataTable().destroy();
                            table.html(data);
                            table1.DataTable({
                                dom: 'lrtpi',
                                pagingType: 'numbers',
                                searching: false
                            });
                    },
                    complete: function () {
                        $('#spinner_loading').hide();
                    }
                });
            });


            function addData() {
                $('#modal_add').modal('show');
            }

            // ACTION EDIT POPULATE
            function btn_edit(id_user, sesa_id, name, level, role, email) {
                $('#id').val(id_user);
                $('#sesa_id').val(sesa_id);
                $('#name').val(name);
                $('#email').val(email);

                // AJAX untuk set value selectpicker (Multi-select)
                $.get('@Url.Action("GetLevelEdit", "Admin")', { level: level }, function (data) {
                    $('#select_level').selectpicker('val', data);
                });
                $.get('@Url.Action("GetRoleEdit", "Admin")', { role: role }, function (data) {
                    $('#edit_role').selectpicker('val', data);
                });

                $("#modal_edit").modal('show');
            }

            // ACTION SAVE EDIT
            // function verify_save() {
            //     const payload = {
            //         id_user: $('#id').val(),
            //         sesa_id: $('#sesa_id').val(),
            //         name: $('#name').val(),
            //         level: ($('#select_level').val() || []).join(';') + ';',
            //         role: ($('#edit_role').val() || []).join(';') + ';'
            //     };

            //     Swal.fire({
            //         title: 'Update User?',
            //         icon: 'warning',
            //         showCancelButton: true,
            //         confirmButtonText: 'Yes, update!'
            //     }).then((result) => {
            //         if (result.isConfirmed) {
            //             $.post("@Url.Action("UpdateUser", "Admin")", payload, function () {
            //                 Swal.fire('Updated!', '', 'success').then(() => window.location.reload());
            //             });
            //         }
            //     });
            // }

            // ACTION SAVE EDIT
            function verify_save() {
                const payload = {
                    id_user: $('#id').val(),
                    sesa_id: $('#sesa_id').val(),
                    name: $('#name').val(),
                    email: $('#email').val(),
                    // Menggabungkan array multi-select menjadi string "level1;level2;"
                    level: ($('#select_level').val() || []).join(';') + ';',
                    role: ($('#edit_role').val() || []).join(';') + ';'
                };

                if (!payload.name || !payload.sesa_id) {
                    return Swal.fire('Error', 'SESA ID and Name are required!', 'error');
                }

                Swal.fire({
                    title: 'Update User?',
                    text: "Are you sure you want to save these changes?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#28a745',
                    cancelButtonColor: '#dc3545',
                    confirmButtonText: 'Yes, update!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#spinner_loading').show();

                        $.post("@Url.Action("UpdateUser", "Admin")", payload, function (response) {
                            $('#spinner_loading').hide();
                            if (response.success) {
                                Swal.fire('Updated!', response.message, 'success').then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        }).fail(function() {
                            $('#spinner_loading').hide();
                            Swal.fire('Error!', 'Server connection failed', 'error');
                        });
                    }
                });
            }

            // ACTION CREATE NEW
            $("#create_Data").click(function () {
                const payload = {
                    sesa_id: $('#sesa_id2').val(),
                    name: $('#name2').val(),
                    password: $('#password').val(),
                    email: $('#email2').val(),
                    level: ($('#select_levelx').val() || []).join(';') + ';',
                    role: ($('#select_rolex').val() || []).join(';') + ';'
                };

                // Validasi input dasar
                if (!payload.sesa_id || !payload.name || !payload.password) {
                    return Swal.fire('Error', 'SESA ID, Name, and Password are required!', 'error');
                }

                $('#spinner_loading').show();

                $.post("@Url.Action("AddUser", "Admin")", payload, function (response) {
                    $('#spinner_loading').hide();
                    if (response.success) {
                        Swal.fire('Success', response.message, 'success').then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire('Error', response.message, 'error');
                    }
                }).fail(function() {
                    $('#spinner_loading').hide();
                    Swal.fire('Error', 'Server error or path not found (404)', 'error');
                });
            });

        // ACTION DELETE SINGLE USER
            function btn_delete(id_user) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545', // Warna Merah
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#spinner_loading').show();

                        $.post("@Url.Action("DeleteUser", "Admin")", { id: id_user }, function (response) {
                            $('#spinner_loading').hide();
                            if (response.success) {
                                Swal.fire('Deleted!', response.message, 'success').then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        }).fail(function() {
                            $('#spinner_loading').hide();
                            Swal.fire('Error!', 'Server connection failed', 'error');
                        });
                    }
                });
            }

        // ACTION DELETE MULTIPLE
            $("#delete_select").click(function () {
                var selectedIds = [];
                $(".select_item:checked").each(function () {
                    selectedIds.Add($(this).val()); // Ambil ID dari checkbox
                });

                if (selectedIds.length === 0) {
                    return Swal.fire('Info', 'Please select at least one user', 'info');
                }

                // Gunakan logika Swal.fire dan $.post yang mirip dengan btn_delete
                // namun kirimkan array ID ke server.
            });
        </script>
    }
</body>
</html>