<script>
    function toggleDailyCheckItems() {
        var container = document.getElementById("dailyCheckContainer");
        var dailyCheckCard = document.getElementById("dailyCheckCard");
        var dailyCheckCardDiv = dailyCheckCard.querySelector('.card');

        container.style.display = (container.style.display === "none") ? "block" : "none";

        if (container.style.display === "block") {
            dailyCheckCardDiv.classList.add("bg-light-gray");
            container.scrollIntoView({ behavior: 'smooth' });
        } else {
            dailyCheckCardDiv.classList.remove("bg-light-gray");
        }
    }

    document.addEventListener('click', function (event) {
        var container = document.getElementById("dailyCheckContainer");
        var checkListLink = document.getElementById("checkListLink");
        var dailyCheckCard = document.getElementById("dailyCheckCard");
        var dailyCheckCardDiv = dailyCheckCard.querySelector('.card');

        if (!container.contains(event.target) && !checkListLink.contains(event.target)) {
            container.style.display = "none";
            dailyCheckCardDiv.classList.remove("bg-light-gray");
        }
    });
</script>

