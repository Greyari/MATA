<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.6.1/TextPlugin.min.js"></script>

<script>
        AOS.init({ once: true, duration: 200 });
        gsap.registerPlugin(TextPlugin);

        // Animasi Judul
        gsap.to("#typing-solutions", {
            duration: 1.5,
            text: "AI-AI Solutions",
            ease: "none"
        });

        // Animasi muncul (fade in) untuk judul
        gsap.from("#typing-solutions", {
            duration: 1.0,
            x: -30,
            opacity: 0,
            ease: "power2.out"
        });

        // Konfigurasi Animasi Mengetik
        // const fullText = "P1F AI-AI Apps is a platform to interact with IQC in an efficient way of communication, open, clear, and transparent. All the key information will be digitized, recorded, and available every time (online).";
        // const fullText = "P1F AI-AI Apps is a digital transformation solution for IQC, facilitating efficient and transparent communication. It ensures that all vital information is recorded digitally and remains accessible online at any time, promoting a seamless and automated data environment.";
    const fullText = "Driving Total Productive Maintenance Excellence in Every Process";

        function startTypingAnimation() {
            let tl = gsap.timeline({ repeat: -1 });

            tl.to("#typing-text", {
                duration: 3,
                text: fullText,
                opacity: 1,
                ease: "none"
            })
            .to({}, { duration: 30 })
            .to("#typing-text", {
                duration: 2,
                opacity: 0,
                ease: "power1.inOut"
            })
            .set("#typing-text", {
                text: ""
            })
            .to({}, { duration: 1 });
        }

        window.addEventListener('load', startTypingAnimation);

        $('#logout-link').on('click', function (event) {
            event.preventDefault();
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, logout!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Logout", "Home")';
                }
            });
        });

        // AOS.init({ once: true, duration: 200 });
        // gsap.registerPlugin(TextPlugin);
        // gsap.to('.display-6', { duration: 1.0, text: 'AI-AI Solutions' });
        // gsap.from('.display-5', { duration: 0.5, x: -50, opacity: 0 });
</script>


