@section Scripts {
<script>
    $(document).ready(function () {
        loadDrawerData();

        // Event saat dropdown berubah
        $('#ddlLine').change(function() {
            loadDrawerData();
            $('#inputQrSearch').val('');
        });

        $('#inputQrSearch').on('keypress', function (e) {
            if (e.which == 13) { 
                performQrSearch();
            }
        });

        $('#inputQrSearch').on('input', function() {
            if ($(this).val().trim() === "") {
                $('.custom-card').removeClass('card-faded card-selected card-animate-pulse');
            }
        });

        // Search Client Side (Table Modal)
        $("#modalTableSearch").on("keyup", function() {
            var value = $(this).val().toLowerCase();
            $("#cableTable tbody tr").filter(function() {
                if($(this).hasClass('level-row-header')) return;
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    });

    // --- 1. FUNGSI BARU: KHUSUS HIGHLIGHT KARTU ---
    // Dipisahkan supaya bisa dipanggil setelah pindah line
    function highlightCard(targetLine, targetLocation) {
        var selector = `.custom-card[data-line='${targetLine}'][data-location='${targetLocation}']`;
        var $targetCardWrapper = $(selector).closest('.grid-item-wrapper');
        var $targetCardInner = $(selector);
        
        if ($targetCardWrapper.length > 0) {
            // A. Scroll ke target
            $targetCardWrapper[0].scrollIntoView({
                behavior: 'smooth',
                block: 'center'
            });

            // B. Efek Visual
            $('.custom-card').addClass('card-faded'); // Pudarkan semua
            
            $targetCardInner.removeClass('card-faded');
            $targetCardInner.addClass('card-selected card-animate-pulse'); // Highlight target

            // C. Timer Stop Animasi
            setTimeout(function() {
                $targetCardInner.removeClass('card-animate-pulse');
            }, 3000); 
        } else {
            // Fallback jika anehnya masih tidak ketemu
            Swal.fire({
                icon: "warning",
                title: "Not Visible",
                text: "Item found in data but not visible on screen."
            });
        }
    }

    // --- 2. MODIFIKASI: PERFORM SEARCH DENGAN LOGIKA PINDAH LINE ---
    function performQrSearch() {
        var qrCode = $('#inputQrSearch').val().trim();

        // Reset visual awal
        $('.custom-card').removeClass('card-faded card-selected card-animate-pulse');

        if (!qrCode) return;

        $.ajax({
            url: "@Url.Action("SearchCableLocation")",
            type: 'GET',
            data: { qrCode: qrCode },
            success: function (response) {
                if (response.success) {
                    var targetLine = response.line;        
                    var targetLocation = response.location; 

                    // --- LOGIKA UTAMA DISINI ---
                    
                    // Cek apakah Line target ada di dalam Dropdown (User punya akses?)
                    // Kita cari option yang value-nya sama dengan targetLine
                    var isLineAccessible = $(`#ddlLine option[value='${targetLine}']`).length > 0;

                    if (isLineAccessible) {
                        var currentLine = $('#ddlLine').val();

                        if (currentLine !== targetLine) {
                            // KASUS: Beda Line -> Pindah Line Dulu
                            
                            // 1. Ubah nilai dropdown
                            $('#ddlLine').val(targetLine);

                            // 2. Load data Line baru, lalu jalankan callback highlight setelah selesai
                            loadDrawerData(function() {
                                // Callback ini jalan SETELAH ajax loadDrawerData selesai & HTML tergambar
                                highlightCard(targetLine, targetLocation);
                            });

                        } else {
                            // KASUS: Line Sama -> Langsung Highlight
                            highlightCard(targetLine, targetLocation);
                        }
                    } else {
                        // KASUS: User tidak punya akses ke Line tersebut
                        Swal.fire({
                            icon: "error",
                            title: "Access Denied",
                            text: `Item found in Line ${targetLine}, but you do not have permission to view this line.`
                        });
                    }

                } else {
                    Swal.fire({ icon: "warning", title: "Not Found", text: response.message });
                }
            },
            error: function () {
                Swal.fire({ icon: "error", title: "Error", text: "Connection error." });
            }
        });
    }

    function applyClientSideFilter() {
        var value = $("#searchInput").val() ? $("#searchInput").val().toLowerCase() : "";
        if (!value) {
            $(".grid-item-wrapper").show();
            return;
        }
        $(".grid-item-wrapper").filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
        });
    }

    // --- 3. MODIFIKASI: TAMBAHKAN PARAMETER CALLBACK (onComplete) ---
    function loadDrawerData(onComplete) {
        var selectedLine = $('#ddlLine').val(); 

        $.ajax({
            url: "@Url.Action("GetDrawerData")",
            type: 'GET',
            data: { line: selectedLine }, 
            dataType: 'json',
            success: function (data) {
                var container = $('#lines-container');
                container.empty();

                if (data.length === 0) {
                    container.html(`
                        <div class="text-center py-5">
                            <i class="fas fa-exclamation-circle text-muted fa-3x mb-3"></i>
                            <p class="text-muted">No configuration found.</p>
                        </div>
                    `);
                    return;
                }

                $.each(data, function (index, line) {
                    var gridStyle = `grid-template-columns: repeat(${line.colNum}, 190px);`;
                    var itemsHtml = '';
                    $.each(line.items, function (i, item) {
                        var alertClass = item.isAlert ? 'alert-mode' : '';
                        var clickAction = `openDetailModal('${line.lineName}', '${item.label}', '${item.subLabel}')`;

                        itemsHtml += `
                            <div class="grid-item-wrapper">
                                <div class="custom-card ${alertClass}"
                                    data-line="${line.lineName}"
                                     data-location="${item.label}"
                                     onclick="${clickAction}"
                                     title="View Details for ${item.label}">
                                    ${item.label ? `<div class="info-badge">${item.label}</div>` : ''}
                                    ${item.subLabel ? `<div class="info-badge" style="background:#fff; color:#333; margin-top:5px;">${item.subLabel}</div>` : ''}
                                </div>
                            </div>
                        `;
                    });

                    var lineHtml = `
                        <div class="line-container">
                            <div class="line-header">
                                <i class="fas fa-network-wired"></i> LINE : ${line.lineName}
                            </div>
                            <div class="dynamic-grid" style="${gridStyle}">
                                ${itemsHtml}
                            </div>
                        </div>
                    `;
                    container.append(lineHtml);
                });

                // Jangan kosongkan inputQrSearch jika ini dipanggil dari search (via callback)
                if(!onComplete) {
                    $('#inputQrSearch').val('');
                }
                
                applyClientSideFilter();

                // --- JALANKAN CALLBACK JIKA ADA ---
                // Ini penting: Memberi tahu pemanggil bahwa HTML sudah selesai dirender
                if (onComplete && typeof onComplete === "function") {
                    onComplete();
                }
            },
            error: function (xhr, status, error) {
                console.error(error);
                $('#lines-container').html(`
                    <div class="alert alert-danger text-center m-4">
                        Failed to load data. Please try again.
                    </div>
                `);
            }
        });
    }

    function openDetailModal(lineName, locationName, subLabel) {
        var isAdmin = @((userLevels.Contains("cm_admin") || userLevels.Contains("superadmin")).ToString().ToLower());
        $('#modalTitle').text(`${lineName} - Location: ${locationName}`);
        $('#modalSubtitle').text(`Data for ${locationName}`);
        $('#detailModal').data('line', lineName);
        $('#detailModal').data('location', locationName);
        $('#modalTableBody').empty();
        $('#modalLoading').show();
        $('#modalCapacityText').text(subLabel);

        if (!$('#detailModal').hasClass('show')) {
            $('#detailModal').modal('show');
        }

        $.ajax({
            url: '@Url.Action("GetCableData")',
            type: 'GET',
            cache: false,
            data: { line: lineName, location: locationName },
            dataType: 'json',
            success: function (data) {
                $('#modalLoading').hide();
                var $tbody = $('#modalTableBody');
                if (data.length === 0) {
                    $tbody.html('<tr><td colspan="6" class="text-center py-4">No cable data found in this location.</td></tr>');
                    return;
                }
                $.each(data, function (i, group) {
                    $tbody.append(`
                        <tr class="level-row-header">
                            <td colspan="6"><i class="fas fa-layer-group mr-2"></i> ${group.name}</td>
                        </tr>
                    `);
                    $.each(group.items, function (j, item) {
                        var statusText = item.status ? item.status.toUpperCase() : "EMPTY";
                        var badgeClass = "st-empty";
                        var badgeLabel = "Empty";
                        if (statusText === "IN") {
                            badgeClass = "st-in";
                            badgeLabel = '<i class="fas fa-check-circle"></i> IN';
                        } else if (statusText === "OUT") {
                            badgeClass = "st-out";
                            badgeLabel = '<i class="fas fa-sign-out-alt"></i> OUT';
                        } else {
                            badgeLabel = "Empty";
                        }
                        var cId = item.cableId || '-';
                        var cPart = item.cablePart || '-';
                        var cDesc = item.cableDescription || '';
                        var uModel = item.unitModel || '';
                        var actionHtml = '';
                        if (cId !== '-' && cId !== 'Empty' && statusText !== 'UNAVAILABLE') {
                            if (statusText === "OUT") {
                                actionHtml = `
                                        <button class="btn btn-sm btn-outline-warning text-nowrap align-items-center" onclick="processReturnInDashboard('${cId}')" title="Return Item">
                                        <i class="fas fa-undo-alt"></i> Return
                                    </button>
                                `;
                            }
                        }
                        var actionCell = '';
                        if (isAdmin) {
                            actionCell = `<td class="text-center">${actionHtml}</td>`;
                        }
                        var rowHtml = `
                            <tr>
                                <td class="font-weight-bold">${cId}</td>
                                <td>${cPart}</td>
                                <td class="text-muted small">${cDesc}</td>
                                <td class="small">${uModel}</td>
                                ${actionCell}
                                <td class="text-center">
                                    <span class="badge-status ${badgeClass}">${badgeLabel}</span>
                                </td>
                            </tr>
                        `;
                        $tbody.append(rowHtml);
                    });
                });
            },
            error: function (xhr) {
                $('#modalLoading').hide();
                $('#modalTableBody').html('<tr><td colspan="6" class="text-danger text-center">Error loading data.</td></tr>');
            }
        });
    }

