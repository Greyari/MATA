    function processReturnInDashboard(cableId) {
        var currentLine = $('#detailModal').data('line');
        var currentLocation = $('#detailModal').data('location');
        Swal.fire({
            title: 'Return Cable?',
            html: `Are you sure you want to return cable <b>${cableId}</b>?<br/>Status will change to <b>IN</b>.`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, Return it!'
        }).then((result) => {
            if (result.value) {
                // var url = '@Url.Action("Return", "Admin")' + '?cableId=' + encodeURIComponent(cableId);
                var url = '@Url.Action("Return", "Admin")';
                window.location.href = url;
            }
        });
    }
