@section Scripts {
<script>
        $(document).ready(function () {
            loadDrawerData();

            if ($('#inputQrSearch').hasClass("select2-hidden-accessible")) {
                $('#inputQrSearch').select2('destroy');
            }

            $('#inputQrSearch').select2({
                placeholder: "Search Cable ID / Unit Model...",
                allowClear: true,
                minimumInputLength: 2,
                width: '100%',
                ajax: {
                    url: "@Url.Action("GetCableSearchSuggestions")",
                    type: "GET",
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { searchTerm: params.term };
                    },
                    processResults: function (data) {
                        return { results: data };
                    },
                    cache: true
                }
            });

            $('#inputQrSearch').on('select2:select', function (e) {
                performQrSearch(e.params.data.id);
            });

            $('#inputQrSearch').on('select2:unselect', function () {
                $('.custom-card').removeClass('card-faded card-selected card-animate-pulse');
            });

            $('#ddlLine').change(function() {
                loadDrawerData();
                $('#inputQrSearch').val(null).trigger('change');
            });
        });

    function highlightCard(targetLine, targetLocation) {
        var selector = `.custom-card[data-line='${targetLine}'][data-location='${targetLocation}']`;
        var $targetCardWrapper = $(selector).closest('.grid-item-wrapper');
        var $targetCardInner = $(selector);
        
        if ($targetCardWrapper.length > 0) {
            $targetCardWrapper[0].scrollIntoView({
                behavior: 'smooth',
                block: 'center'
            });

            $('.custom-card').addClass('card-faded');
            
            $targetCardInner.removeClass('card-faded');
            $targetCardInner.addClass('card-selected card-animate-pulse');

            setTimeout(function() {
                $targetCardInner.removeClass('card-animate-pulse');
            }, 3000); 
        } else {
            Swal.fire({
                icon: "warning",
                title: "Not Visible",
                text: "Item found in data but not visible on screen."
            });
        }
    }

        function performQrSearch(qrCode) {
            $('.custom-card').removeClass('card-faded card-selected card-animate-pulse');

            if (!qrCode) return;

            $.ajax({
                url: "@Url.Action("SearchCableLocation")",
                type: 'GET',
                data: { qrCode: qrCode },
                success: function (response) {
                    if (response.success && response.data.length > 0) {
                        var targets = response.data;

                        $('.custom-card').addClass('card-faded');

                        targets.forEach(function(item) {
                            var selector = `.custom-card[data-line='${item.line}'][data-location='${item.location}']`;
                            var $targetCard = $(selector);

                            if ($targetCard.length > 0) {
                                $targetCard.removeClass('card-faded');
                                $targetCard.addClass('card-selected card-animate-pulse');

                                setTimeout(function() {
                                    $targetCard.removeClass('card-animate-pulse');
                                }, 3000);
                            }
                        });

                        var firstMatchSelector = `.custom-card[data-line='${targets[0].line}'][data-location='${targets[0].location}']`;
                        var $firstMatch = $(firstMatchSelector);

                        if ($firstMatch.length > 0) {
                            $firstMatch[0].scrollIntoView({
                                behavior: 'smooth',
                                block: 'center'
                            });
                        } else {
                            handleTargetHighlight(targets[0].line, targets[0].location);
                        }

                    } else {
                        Swal.fire({ icon: "warning", title: "Not Found", text: response.message });
                    }
                },
                error: function() {
                    Swal.fire({ icon: "error", title: "Error", text: "Failed to fetch search data." });
                }
            });
        }

    function handleTargetHighlight(targetLine, targetLocation) {
        var isLineAccessible = $(`#ddlLine option[value='${targetLine}']`).length > 0;

        if (isLineAccessible) {
            var currentLine = $('#ddlLine').val();
        
            if (currentLine !== targetLine) {
                $('#ddlLine').val(targetLine);
            
                loadDrawerData(function() {
                    setTimeout(function() {
                        highlightCard(targetLine, targetLocation);
                    }, 300) ;
                });
            } else {
                highlightCard(targetLine, targetLocation);
            }
        } else {
            Swal.fire({ icon: "error", title: "Access Denied", text: "You don't have access to Line " + targetLine });
        }
    }
    function applyClientSideFilter() {
        var value = $("#searchInput").val() ? $("#searchInput").val().toLowerCase() : "";
        if (!value) {
            $(".grid-item-wrapper").show();
            return;
        }
        $(".grid-item-wrapper").filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
        });
    }

    function loadDrawerData(onComplete) {
        var selectedLine = $('#ddlLine').val(); 

        $.ajax({
            url: "@Url.Action("GetDrawerData")",
            type: 'GET',
            data: { line: selectedLine }, 
            dataType: 'json',
            success: function (data) {
                var container = $('#lines-container');
                container.empty();

                if (data.length === 0) {
                    container.html(`
                        <div class="text-center py-5">
                            <i class="fas fa-exclamation-circle text-muted fa-3x mb-3"></i>
                            <p class="text-muted">No configuration found.</p>
                        </div>
                    `);
                    return;
                }

                $.each(data, function (index, line) {
                    var gridStyle = `grid-template-columns: repeat(${line.colNum}, 190px);`;
                    var itemsHtml = '';
                    $.each(line.items, function (i, item) {
                        var statusClass = '';

                        // if (item.subLabel === "-") {
                        if (item.subLabel === "-" || (item.subLabel && item.subLabel.startsWith("0/"))) {
                            statusClass = 'empty-mode';
                        } else if (item.isAlert) {
                            statusClass = 'alert-mode';
                        } else {
                            statusClass = 'available-mode';
                        }

                        var clickAction = `openDetailModal('${line.lineName}', '${item.label}', '${item.subLabel}')`;

                        itemsHtml += `
                            <div class="grid-item-wrapper">
                                <div class="custom-card ${statusClass}"
                                     data-line="${line.lineName}"
                                     data-location="${item.label}"
                                     onclick="${clickAction}"
                                     title="View Details for ${item.label}">
                                    ${item.label ? `<div class="info-badge">${item.label}</div>` : ''}
                                    ${item.subLabel ? `<div class="info-badge" style="background:#fff; color:#333; margin-top:5px;">${item.subLabel}</div>` : ''}
                                </div>
                            </div>
                        `;
                    });

                    var lineHtml = `
                        <div class="line-container">
                            <div class="line-header">
                                <i class="fas fa-network-wired"></i> LINE : ${line.lineName}
                            </div>
                            <div class="dynamic-grid" style="${gridStyle}">
                                ${itemsHtml}
                            </div>
                        </div>
                    `;
                    container.append(lineHtml);
                });

                if(!onComplete) {
                    $('#inputQrSearch').val('');
                }
                
                applyClientSideFilter();

                if (onComplete && typeof onComplete === "function") {
                    onComplete();
                }
            },
            error: function (xhr, status, error) {
                console.error(error);
                $('#lines-container').html(`
                    <div class="alert alert-danger text-center m-4">
                        Failed to load data. Please try again.
                    </div>
                `);
            }
        });
    }

    function openDetailModal(lineName, locationName, subLabel) {
        var isAdmin = @((userLevels.Contains("cm_admin") || userLevels.Contains("superadmin")).ToString().ToLower());
        $('#modalTitle').text(`${lineName} - Location: ${locationName}`);
        $('#modalSubtitle').text(`Data for ${locationName}`);
        $('#detailModal').data('line', lineName);
        $('#detailModal').data('location', locationName);
        $('#modalTableBody').empty();
        $('#modalLoading').show();
        $('#modalCapacityText').text(subLabel);

        if (!$('#detailModal').hasClass('show')) {
            $('#detailModal').modal('show');
        }

        $.ajax({
            url: '@Url.Action("GetCableData")',
            type: 'GET',
            cache: false,
            data: { line: lineName, location: locationName },
            dataType: 'json',
            success: function (data) {
                $('#modalLoading').hide();
                var $tbody = $('#modalTableBody');
                if (data.length === 0) {
                    $tbody.html('<tr><td colspan="6" class="text-center py-4">No cable data found in this location.</td></tr>');
                    return;
                }
                $.each(data, function (i, group) {
                    $tbody.append(`
                        <tr class="level-row-header">
                            <td colspan="6"><i class="fas fa-layer-group mr-2"></i> ${group.name}</td>
                        </tr>
                    `);
                    $.each(group.items, function (j, item) {
                        var statusText = item.status ? item.status.toUpperCase() : "EMPTY";
                        var badgeClass = "st-empty";
                        var badgeLabel = "Empty";
                        if (statusText === "IN") {
                            badgeClass = "st-in";
                            badgeLabel = '<i class="fas fa-check-circle"></i> IN';
                        } else if (statusText === "OUT") {
                            badgeClass = "st-out";
                            badgeLabel = '<i class="fas fa-sign-out-alt"></i> OUT';
                        } else {
                            badgeLabel = "Empty";
                        }
                        var cId = item.cableId || '-';
                        var cPart = item.cablePart || '-';
                        var cDesc = item.cableDescription || '';
                        var uModel = item.unitModel || '';
                        var actionHtml = '';
                        if (cId !== '-' && cId !== 'Empty' && statusText !== 'UNAVAILABLE') {
                            if (statusText === "OUT") {
                                actionHtml = `
                                    <button class="btn btn-sm btn-outline-warning text-nowrap" onclick="processReturnInDashboard('${cId}')" title="Return Item">
                                        <i class="fas fa-undo-alt"></i> Return
                                    </button>`;
                            } else if (statusText === "IN") {
                                actionHtml = `
                                    <button class="btn btn-sm btn-outline-primary text-nowrap" onclick="processBorrowInDashboard('${lineName}', '${locationName}')" title="Borrow Item">
                                        <i class="fas fa-sign-out-alt"></i> Borrow
                                    </button>`;
                            }
                        }
                        var actionCell = '';
                        if (isAdmin) {
                            actionCell = `<td class="text-center">${actionHtml}</td>`;
                        }
                        var rowHtml = `
                            <tr>
                                <td class="font-weight-bold">${cId}</td>
                                <td>${cPart}</td>
                                <td class="text-muted small">${cDesc}</td>
                                <td class="small">${uModel}</td>
                                ${actionCell}
                                <td class="text-center">
                                    <span class="badge-status ${badgeClass}">${badgeLabel}</span>
                                </td>
                            </tr>
                        `;
                        $tbody.append(rowHtml);
                    });
                });
            },
            error: function (xhr) {
                $('#modalLoading').hide();
                $('#modalTableBody').html('<tr><td colspan="6" class="text-danger text-center">Error loading data.</td></tr>');
            }
        });
    }

    function processBorrowInDashboard(line, location) {
        Swal.fire({
            title: 'Borrow from this location?',
            html: `You will be redirected to Borrow page for:<br><b>${line} - ${location}</b>`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#2E8B57',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, Go to Borrow'
        }).then((result) => {
            if (result.value) {
                var url = '@Url.Action("Borrow", "CMS")' + 
                          '?line=' + encodeURIComponent(line) + 
                          '&location=' + encodeURIComponent(location);
            
                window.location.href = url;
            }
        });
    }
    
    function processReturnInDashboard(cableId) {
        var currentLine = $('#detailModal').data('line');
        var currentLocation = $('#detailModal').data('location');
        Swal.fire({
            title: 'Return Cable?',
            html: `Are you sure you want to return cable <b>${cableId}</b>?<br/>Status will change to <b>IN</b>.`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, Return it!'
        }).then((result) => {
            if (result.value) {
                var url = '@Url.Action("Return", "CMS")';
                window.location.href = url;
            }
        });
    }
</script>
}