@{
    Layout = "~/Views/Shared/_LayoutCMS.cshtml";
    ViewData["Title"] = "Cable Return Wizard";
}

<style>
    /* --- STYLE BAWAAN --- */
    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 40px;
        position: relative;
        padding: 0 50px;
    }

    .stepper-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }

        .stepper-item::before {
            content: '';
            position: absolute;
            top: 20px;
            left: -50%;
            width: 100%;
            height: 2px;
            background-color: #e0e0e0;
            z-index: 1;
        }

        .stepper-item:first-child::before {
            content: none;
        }

    .step-counter {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #6c757d;
        color: #fff;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
        margin-bottom: 6px;
        transition: all 0.3s ease;
        position: relative;
        z-index: 5;
    }

    .step-name {
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 500;
    }

    .stepper-item.active .step-counter {
        background-color: #dbeafe;
        color: #1e40af;
        border: 2px solid #1e40af;
    }

    .stepper-item.active .step-name {
        color: #1e40af;
        font-weight: bold;
    }

    .stepper-item.completed .step-counter {
        background-color: #d1fae5;
        color: #065f46;
    }

    .stepper-item.completed::before {
        background-color: #10b981;
    }

    .stepper-item.completed .step-name {
        color: #065f46;
    }

    .wizard-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 40px;
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
        min-height: 350px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .scanner-input {
        font-size: 1.5rem;
        text-align: center;
        letter-spacing: 2px;
        border: 2px solid #ddd;
        border-radius: 8px;
        padding: 15px;
        width: 100%;
        margin-top: 20px;
        transition: border-color 0.3s;
    }

        .scanner-input:focus {
            border-color: #3dcd58;
            outline: none;
            box-shadow: 0 0 0 4px rgba(61, 205, 88, 0.1);
        }

    .helper-text {
        color: #888;
        font-size: 0.9rem;
        margin-top: 10px;
        font-style: italic;
    }

    .hidden-step {
        display: none;
    }

    .scan-icon-anim {
        font-size: 4rem;
        color: #3dcd58;
        margin-bottom: 20px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.7;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<div class="container pt-5 pb-5">

    <div class="stepper-wrapper">
        <div class="stepper-item active" id="indicator-1">
            <div class="step-counter">1</div>
            <div class="step-name">Scan Cable</div>
        </div>
        <div class="stepper-item" id="indicator-3">
            <div class="step-counter">2</div>
            <div class="step-name">Finish</div>
        </div>
    </div>

    <div class="wizard-card">
        <div id="step-1-content">
            <i class="fas fa-barcode scan-icon-anim"></i>
            <h3>Step 1: Scan Cable QR</h3>
            <p class="text-muted">Scan the QR code on the cable to return it. You can scan multiple cables.</p>

            <input type="text" id="inputCable" class="scanner-input" placeholder="Scan Cable ID..." autofocus autocomplete="off">

            <div class="mt-4 text-left">
                <label class="small font-weight-bold text-success">
                    <i class="fas fa-history"></i> Recent Activity @*<span class="text-muted">(Last 10 Minutes)</span>: *@
                </label>
                <div class="table-responsive" style="max-height: 200px; overflow-y: auto; border: 1px solid #eee; border-radius: 8px;">
                    <table class="table table-sm table-striped mb-0" id="tempReturnTable">
                        <thead class="bg-light">
                            <tr>
                                <th>Cable ID</th>
                                <th>Location</th>
                                <th>Time</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="tempReturnBody">
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-4">
                <button id="btnFinishReturn" class="btn btn-success btn-lg btn-block" onclick="finishReturnTransaction()" disabled>
                    Finish <i class="fas fa-check-circle ml-2"></i>
                </button>
            </div>
        </div>

        <div id="step-3-content" class="hidden-step">
            <div class="text-center">
                <i class="fas fa-check-circle text-success" style="font-size: 5rem; margin-bottom: 20px;"></i>
                <h2 class="text-success">Return Success!</h2>
                <p>All scanned cables have been successfully returned to their respective locations.</p>

                <div class="card bg-light border-0 p-3 mt-3 mb-4 text-left d-inline-block" style="min-width: 350px;">
                    <div><strong>Total Cables:</strong> <span id="summaryCount">0</span></div>
                    <div id="summaryListArea" class="mt-2 small">
                        <strong>Details:</strong>
                        <ul id="summaryDetails" class="mb-0"></ul>
                    </div>
                    <div class="mt-2"><strong>Time:</strong> <span id="summaryTime"></span></div>
                </div>

                <div>
                    <button class="btn btn-primary" onclick="resetProcess()">Return More Cables</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var returnedItems = []; // Array untuk menampung data temporary

        $(document).ready(function() {
            $('#inputCable').focus();
            loadReturnHistory();

            $('#inputCable').on('keypress', function(e) {
                if(e.which == 13) {
                    var code = $(this).val().trim();
                    if(code !== "") {
                        processDirectReturn(code);
                    }
                }
            });
        });

        function loadReturnHistory() {
            $.ajax({
                url: "@Url.Action("GetReturnHistory")",
                type: "GET",
                success: function(data) {
                    var $tbody = $('#tempReturnBody');
                    $tbody.empty();
                    returnedItems = []; // Reset local list

                    if (data.length > 0) {
                        $('#btnFinishReturn').prop('disabled', false);
                        $.each(data, function(i, item) {
                            var row = `<tr>
                                <td class="font-weight-bold">${item.cable_id}</td>
                                <td><span class="badge badge-info">${item.location}</span></td>
                                <td class="text-muted small">${item.return_date}</td>
                                <td class="text-center">
                                    <button class="btn btn-xs btn-outline-danger" onclick="deleteReturnItem('${item.order_id}', '${item.cable_id}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>`;
                            $tbody.append(row);
                            // Update array untuk summary di Step Terakhir
                            returnedItems.push({ id: item.cable_id, loc: item.location, time: item.return_date, qr: item.cable_id });
                        });
                    } else {
                        $('#btnFinishReturn').prop('disabled', true);
                        $tbody.append('<tr><td colspan="4" class="text-center text-muted small py-3">No cables scanned yet</td></tr>');
                    }
                }
            });
        }

        function deleteReturnItem(orderId, cableId) {
            Swal.fire({
                title: "Cancel Return?",
                text: "Remove cable " + cableId + " from list?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, Remove!"
            }).then((result) => {
                if (result.value || result.isConfirmed) {
                    $.ajax({
                        url: "@Url.Action("DeleteReturnItem")",
                        type: "POST",
                        data: { order_id: orderId },
                        success: function(response) {
                            if (response.success) {
                                loadReturnHistory();
                                Swal.fire({ icon: 'success', title: 'Removed', timer: 1500, showConfirmButton: false });
                            } else {
                                Swal.fire("Error", response.message, "error");
                            }
                        }
                    });
                }
            });
        }

                function processDirectReturn(cableCode, isConfirmed = false) {
            if (!isConfirmed && returnedItems.some(x => x.qr === cableCode)) {
                Swal.fire("Warning", "Cable already in the return list.", "warning");
                $('#inputCable').val('').focus();
                return;
            }

            let loadingTitle = isConfirmed ? 'Processing Return...' : 'Checking Cable...';
            // Gunakan onOpen jika menggunakan SweetAlert versi lama
            Swal.fire({
                title: loadingTitle,
                allowOutsideClick: false,
                onOpen: () => Swal.showLoading()
            });

            $.ajax({
                url: "@Url.Action("ProcessReturn")",
                type: 'POST',
                data: {
                    cable_qr: cableCode,
                    isConfirmed: isConfirmed
                },
                success: function(response) {
                    // JANGAN panggil Swal.close() manual di sini jika ingin membuka modal konfirmasi
                    if (response.success) {
                        if (response.requiresConfirmation) {
                            Swal.fire({
                                title: "Confirm Return?",
                                html: `Return: <b>${response.cableId}</b><br>To: <b>${response.location}</b>`,
                                icon: "question",
                                showCancelButton: true,
                                confirmButtonColor: "#3dcd58",
                                confirmButtonText: "Yes, Return it!"
                            }).then((result) => {
                                // Perbaikan: Mendukung result.value (Swal lama) dan result.isConfirmed (Swal baru)
                                if (result.value || result.isConfirmed) {
                                    // PEMANGGILAN KEDUA: Kirim true agar Controller mengeksekusi SP
                                    processDirectReturn(cableCode, true);
                                } else {
                                    $('#inputCable').val('').focus();
                                }
                            });
                        } else {
                            // Jika sudah sukses (Setelah pemanggilan kedua)
                            loadReturnHistory(); // PERBAIKAN: Tambahkan tanda kurung ()

                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: 'Cable ' + response.summaryCableId + ' returned',
                                timer: 1500,
                                showConfirmButton: false
                            });

                            $('#inputCable').val('').focus();
                        }
                    } else {
                        Swal.fire({ icon: "error", title: "Failed", text: response.message });
                        $('#inputCable').val('').focus();
                    }
                },
                error: function() {
                    Swal.fire({ icon: "error", title: "Error", text: "Connection failed" });
                }
            });
        }

        function addToTempReturnList(cableId, location, qrCode) {
            var now = new Date().toLocaleTimeString();
            if (returnedItems.length === 0) $('#tempReturnBody').empty();

            returnedItems.push({ id: cableId, loc: location, time: now, qr: qrCode });

            var row = `<tr>
                <td class="font-weight-bold">${cableId}</td>
                <td><span class="badge badge-info">${location}</span></td>
                <td class="text-muted small">${now}</td>
            </tr>`;

            $('#tempReturnBody').prepend(row);
            $('#btnFinishReturn').prop('disabled', false);
        }

        function finishReturnTransaction() {
            $('#summaryCount').text(returnedItems.length);
            $('#summaryTime').text(new Date().toLocaleString());

            var listHtml = returnedItems.map(item => `<li><b>${item.id}</b> to ${item.loc}</li>`).join('');
            $('#summaryDetails').html(listHtml);

            goToStep(3);
        }

        function goToStep(stepNumber) {
            $('#step-1-content, #step-3-content').hide();
            $(`#step-${stepNumber}-content`).fadeIn();
            updateStepperVisuals(stepNumber);
        }

        function resetProcess() {
            returnedItems = [];
            $('#tempReturnBody').html('<tr><td colspan="3" class="text-center text-muted small py-3">No cables scanned yet</td></tr>');
            $('#btnFinishReturn').prop('disabled', true);
            $('#inputCable').val('');
            goToStep(1);
            setTimeout(() => $('#inputCable').focus(), 200);
        }

        function updateStepperVisuals(currentStep) {
            // Step 1: counter 1, Step 3: counter 2 (di visualisasi stepper Anda)
            if (currentStep === 1) {
                $('#indicator-1').addClass('active').removeClass('completed');
                $('#indicator-3').removeClass('active completed');
            } else {
                $('#indicator-1').addClass('completed').removeClass('active');
                $('#indicator-3').addClass('completed');
            }
        }
    </script>
}