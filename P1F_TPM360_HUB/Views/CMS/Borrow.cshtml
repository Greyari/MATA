@{
    Layout = "~/Views/Shared/_LayoutCMS.cshtml";
    ViewData["Title"] = "Cable Borrow Wizard";
}

<style>
    /* --- STEPPER STYLE (Sama dengan halaman Return) --- */
    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 40px;
        position: relative;
        padding: 0 50px;
    }

    .stepper-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }

        .stepper-item::before {
            content: '';
            position: absolute;
            top: 20px;
            left: -50%;
            width: 100%;
            height: 2px;
            background-color: #e0e0e0;
            z-index: 1;
        }

        .stepper-item:first-child::before {
            content: none;
        }

    .step-counter {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #6c757d;
        color: #fff;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
        margin-bottom: 6px;
        transition: all 0.3s ease;
        position: relative;
        z-index: 5;
    }

    .step-name {
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 500;
    }

    /* Active State */
    .stepper-item.active .step-counter {
        background-color: #dbeafe;
        color: #1e40af;
        border: 2px solid #1e40af;
    }

    .stepper-item.active .step-name {
        color: #1e40af;
        font-weight: bold;
    }

    /* Completed State */
    .stepper-item.completed .step-counter {
        background-color: #d1fae5;
        color: #065f46;
    }

    .stepper-item.completed::before {
        background-color: #10b981;
    }

    .stepper-item.completed .step-name {
        color: #065f46;
    }

    /* --- FORM CARD STYLING --- */
    .wizard-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 40px;
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
        min-height: 350px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .scanner-input {
        font-size: 1.5rem;
        text-align: center;
        letter-spacing: 2px;
        border: 2px solid #ddd;
        border-radius: 8px;
        padding: 15px;
        width: 100%;
        margin-top: 20px;
        transition: border-color 0.3s;
    }

        .scanner-input:focus {
            border-color: #3dcd58; /* Schneider Green */
            outline: none;
            box-shadow: 0 0 0 4px rgba(61, 205, 88, 0.1);
        }

    .helper-text {
        color: #888;
        font-size: 0.9rem;
        margin-top: 10px;
        font-style: italic;
    }

    .hidden-step {
        display: none;
    }

    .scan-icon-anim {
        font-size: 4rem;
        color: #007bff; /* Blue for Borrowing */
        margin-bottom: 20px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.7;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<div class="container pt-5 pb-5">

    <div class="stepper-wrapper">
        <div class="stepper-item active" id="indicator-1">
            <div class="step-counter">1</div>
            <div class="step-name">Select Location</div>
        </div>
        <div class="stepper-item" id="indicator-2">
            <div class="step-counter">2</div>
            <div class="step-name">Scan Cable</div>
        </div>
        <div class="stepper-item" id="indicator-3">
            <div class="step-counter">3</div>
            <div class="step-name">Finish</div>
        </div>
    </div>

    <div class="wizard-card">

        <div id="step-1-content">
            <i class="fas fa-map-marker-alt scan-icon-anim"></i>
            <h3>Step 1: Select Location</h3>
            <p class="text-muted">Select the Cell and Location to borrow the cable.</p>

            <div class="row no-gutters mb-4">
                <div class="col-md-6 px-1">
                    <div class="text-left">
                        <label class="small font-weight-bold">Select Cell:</label>
                        <select id="selectLine" class="form-control form-control-lg">
                            <option value="">-- Choose Cell --</option>
                            @foreach (var line in ViewBag.LineList)
                            {
                                <option value="@line">@line</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6 px-1">
                    <div class="text-left">
                        <label class="small font-weight-bold">Select Location:</label>
                        <select id="selectLocation" class="form-control form-control-lg" disabled>
                            <option value="">-- Choose Location --</option>
                        </select>
                    </div>
                </div>
            </div>

            <button id="btnNext1" class="btn btn-primary btn-block btn-lg" disabled onclick="nextToStep2()">
                Next <i class="fas fa-arrow-right ml-2"></i>
            </button>
        </div>

        <div id="step-2-content" class="hidden-step">
            <i class="fas fa-barcode scan-icon-anim text-success"></i>
            <h3>Step 2: Scan Cable QR</h3>
            <p class="text-muted">Scan the QR code on the cable. You can scan multiple cables from this location.</p>

            <div class="alert alert-primary py-2 mb-3" style="font-size: 0.9rem;">
                <strong>Taking from:</strong> <span id="displayLocation">---</span>
            </div>

            <input type="text" id="inputCable" class="scanner-input" placeholder="Scan Cable ID..." autocomplete="off">

            <div class="mt-4 text-left">
                <label class="small font-weight-bold text-primary">
                    <i class="fas fa-history"></i> Recent Activity  @*<span class="text-muted">(Last 10 Minutes)</span>: *@
                </label>
                <div class="table-responsive" style="max-height: 200px; overflow-y: auto; border: 1px solid #eee; border-radius: 8px;">
                    <table class="table table-sm table-striped mb-0" id="tempScanTable">
                        <thead class="bg-light">
                            <tr>
                                <th>Cable ID</th>
                                <th>Location</th>
                                <th>Time</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="tempScanBody">
                            <tr>
                                <td colspan="3" class="text-center text-muted small py-3">No cables scanned yet</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <button class="btn btn-secondary" onclick="prevStep(1)">Back</button>
                <button id="btnFinish" class="btn btn-success px-5" onclick="finishTransaction()" disabled>
                    Finish <i class="fas fa-check-circle ml-2"></i>
                </button>
            </div>
        </div>
        <div id="step-3-content" class="hidden-step">
            <div class="text-center">
                <i class="fas fa-clipboard-check text-primary" style="font-size: 5rem; margin-bottom: 20px;"></i>
                <h2 class="text-primary">Borrow Success!</h2>
                <p>The cable has been recorded as borrowed.</p>

                <div class="card bg-light border-0 p-3 mt-3 mb-4 text-left d-inline-block" style="min-width: 300px;">
                    <div><strong>Source Location:</strong> <span id="summaryLoc"></span></div>
                    <div><strong>Total Scanned:</strong> <span id="summaryCable"></span></div>
                    <div><strong>Last Activity:</strong> <span id="summaryTime"></span></div>
                </div>

                <div>
                    <button class="btn btn-outline-primary" onclick="resetProcess()">Borrow Another Cable</button>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        var currentLocationQR = "";
        var scannedItems = [];

        $(document).ready(function() {
            // 1. Ambil Parameter dari URL
            const urlParams = new URLSearchParams(window.location.search);
            const urlLine = urlParams.get('line');
            const urlLocation = urlParams.get('location');

            // 2. Jika ada parameter URL, jalankan Auto-Select
            if (urlLine && urlLocation) {
                autoSelectLocation(urlLine, urlLocation);
            }

            // --- Event Handler ---
            $('#selectLine').on('change', function() {
                loadLocations($(this).val());
            });

            $('#selectLocation').on('change', function() {
                $('#btnNext1').prop('disabled', $(this).val() === "");
            });

            $('#inputCable').on('keypress', function(e) {
                if(e.which == 13) {
                    var cableCode = $(this).val().trim();
                    if(cableCode !== "") {
                        processBorrow(cableCode);
                    }
                }
            });
            loadBorrowHistory();
        });

        function loadBorrowHistory() {
            $.ajax({
                url: "@Url.Action("GetBorrowHistory")",
                type: "GET",
                success: function(data) {
                    var $tbody = $('#tempScanBody');
                    $tbody.empty();

                    if (data.length > 0) {
                        // Update counter di tombol Finish jika ada data open
                        $('#btnFinish').prop('disabled', false);

                        $.each(data, function(i, item) {
                            var row = `<tr>
                                <td class="font-weight-bold">${item.cable_id}</td>
                                <td><span class="badge badge-primary">${item.location}</span></td>
                                <td class="text-muted small">${item.borrow_date}</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteItem('${item.order_id}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>`;
                            $tbody.append(row);

                            // Masukkan ke array scannedItems agar sinkron dengan summary di Step 3
                            if(!scannedItems.some(x => x.id === item.cable_id)) {
                                scannedItems.push({ id: item.cable_id, loc: item.location, time: item.borrow_date });
                            }
                        });
                    } else {
                        $tbody.append('<tr><td colspan="4" class="text-center text-muted small py-3">No cables scanned yet</td></tr>');
                    }
                }
            });
        }

        function deleteItem(orderId) {
            Swal.fire({
                title: "Cancel Borrow?",
                text: "This item will be removed from your recent list.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Yes, Remove!"
            }).then((result) => {
                if (result.value || result.isConfirmed) {
                    $.ajax({
                        url: "@Url.Action("DeleteBorrowItem")",
                        type: "POST",
                        data: { order_id: orderId },
                        success: function(response) {
                            if (response.success) {
                                // Refresh history setelah berhasil hapus
                                loadBorrowHistory();

                                Swal.mixin({
                                    toast: true,
                                    position: 'top-end',
                                    showConfirmButton: false,
                                    timer: 2000
                                }).fire({ icon: 'success', title: 'Item removed' });
                            } else {
                                Swal.fire("Error", response.message, "error");
                            }
                        }
                    });
                }
            });
        }

        // Fungsi memuat lokasi (digunakan manual & otomatis)
        function loadLocations(selectedLine, targetLocationName = null) {
            var $locDropdown = $('#selectLocation');
            $locDropdown.empty().append('<option value="">-- Choose Location --</option>').prop('disabled', true);
            $('#btnNext1').prop('disabled', true);

            if (selectedLine !== "") {
                // Return promise ajax agar .done() bisa digunakan di autoSelect
                return $.ajax({
                    url: "@Url.Action("GetLocationsByLine")",
                    type: "GET",
                    data: { line: selectedLine },
                    success: function(data) {
                        $.each(data, function(i, item) {
                            var isStockOut = item.available_qty <= 0;
                            var text = item.location + (isStockOut ? " (Not Available)" : " (Qty: " + item.available_qty + ")");

                            var option = $('<option>', {
                                value: item.qr_code,
                                text: text,
                                disabled: isStockOut
                            });
                            $locDropdown.append(option);

                            // Pilih otomatis jika cocok dengan parameter URL
                            if (targetLocationName && item.location === targetLocationName) {
                                $locDropdown.val(item.qr_code);
                            }
                        });
                        $locDropdown.prop('disabled', false);
                        // Aktifkan tombol next jika dropdown terisi otomatis
                        if($locDropdown.val()) $('#btnNext1').prop('disabled', false);
                    }
                });
            }
        }

        // Fungsi Otomatis melompat ke Step 2 jika URL tersedia
        function autoSelectLocation(line, locationName) {
            $('#selectLine').val(line);
            var loader = loadLocations(line, locationName);

            if(loader) {
                loader.done(function() {
                    var selectedQR = $('#selectLocation').val();
                    if (selectedQR) {
                        nextToStep2();
                    } else {
                        Swal.fire("Warning", "Location " + locationName + " is empty or not available.", "warning");
                    }
                });
            }
        }

        function nextToStep2() {
            var qrCode = $('#selectLocation').val();
            var locName = $('#selectLine').val() + " - " + $('#selectLocation option:selected').text().split(' (')[0];

            if(!qrCode) return;

            currentLocationQR = qrCode;
            $('#displayLocation').text(locName);
            goToStep(2);
        }

        function processBorrow(cableCode, isConfirmed = false) {
            if (!isConfirmed && scannedItems.some(x => x.id === cableCode)) {
                Swal.fire("Warning", "Cable " + cableCode + " is already in the list.", "warning");
                $('#inputCable').val('').focus();
                return;
            }

            // Gunakan onOpen untuk versi lama
            Swal.fire({
                title: isConfirmed ? 'Borrowing...' : 'Checking Cable...',
                allowOutsideClick: false,
                onOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: "@Url.Action("ProcessBorrow")",
                type: 'POST',
                data: {
                    cable_qr: cableCode,
                    drawer_qr: currentLocationQR,
                    isConfirmed: isConfirmed
                },
                success: function(response) {
                    if (response.success) {
                        if (response.requiresConfirmation) {
                            // Modal konfirmasi otomatis menutup modal loading sebelumnya
                            Swal.fire({
                                title: "Confirm Borrow",
                                html: "Borrow <b>" + response.cableId + "</b>?<br>" + response.description,
                                icon: "question",
                                showCancelButton: true,
                                confirmButtonColor: "#3dcd58",
                                confirmButtonText: "Yes, Borrow!"
                            }).then((result) => {
                                // Di Swal versi lama, result terkadang berupa boolean langsung atau object dengan property 'value'
                                if (result.value || result === true) {
                                    processBorrow(cableCode, true);
                                } else {
                                    $('#inputCable').val('').focus();
                                }
                            });
                        } else {
                            // Berhasil dieksekusi (setelah isConfirmed = true)
                            var locName = $('#displayLocation').text();
                            addToTempList(response.realCableId, locName);

                            loadBorrowHistory();

                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: 'Cable ' + response.realCableId + ' borrowed',
                                timer: 1500,
                                showConfirmButton: false
                            });

                            $('#inputCable').val('').focus();
                        }
                    } else {
                        Swal.fire({ icon: "error", title: "Error", text: response.message });
                        $('#inputCable').val('').focus();
                    }
                },
                error: function() {
                    Swal.fire({ icon: "error", title: "Error", text: "Server connection failed" });
                }
            });
        }

        function addToTempList(cableId, location) {
            var now = new Date().toLocaleTimeString();
            if (scannedItems.length === 0) $('#tempScanBody').empty();

            scannedItems.push({ id: cableId, loc: location, time: now });

            var row = `<tr>
                <td class="font-weight-bold">${cableId}</td>
                <td><span class="badge badge-primary">${location}</span></td>
                <td class="text-muted small">${now}</td>
            </tr>`;
            $('#tempScanBody').prepend(row);
            $('#btnFinish').prop('disabled', false);
        }

        function finishTransaction() {
            // Isi Summary Data
            $('#summaryCable').text(scannedItems.length + " Cables");
            $('#summaryTime').text(new Date().toLocaleString());
            $('#summaryLoc').text($('#displayLocation').text());

            // Buat list detail
            var listHtml = '<ul class="pl-3 mb-0">';
            scannedItems.forEach(function(item) {
                listHtml += `<li><b>${item.id}</b> <small class="text-muted">(${item.time})</small></li>`;
            });
            listHtml += '</ul>';

            // Bersihkan div detail lama jika ada, lalu tambah yang baru
            $('#summaryDetail').remove();
            $('.wizard-card #step-3-content .card').append(`<div id="summaryDetail" class="mt-2 border-top pt-2">${listHtml}</div>`);

            goToStep(3);
        }

        function goToStep(stepNumber) {
            $('#step-1-content, #step-2-content, #step-3-content').hide();
            $(`#step-${stepNumber}-content`).fadeIn();
            updateStepperVisuals(stepNumber);

            if (stepNumber === 2) {
                setTimeout(() => $('#inputCable').val('').focus(), 200);
            }
        }

        function prevStep(stepNumber) {
            goToStep(stepNumber);
        }

        function resetProcess() {
            // Bersihkan data temporary
            scannedItems = [];
            $('#tempScanBody').html('<tr><td colspan="2" class="text-center text-muted small py-3">No cables scanned yet</td></tr>');
            $('#btnFinish').prop('disabled', true);

            // Bersihkan form
            $('#selectLine').val('');
            $('#selectLocation').empty().append('<option value="">-- Choose Location --</option>').prop('disabled', true);
            $('#btnNext1').prop('disabled', true);
            $('#inputCable').val('');
            currentLocationQR = "";

            // Kembali ke Step 1 (Tanpa parameter URL lagi)
            window.history.replaceState({}, document.title, window.location.pathname);
            goToStep(1);
        }

        function updateStepperVisuals(currentStep) {
            $('.stepper-item').removeClass('active completed');
            for (let i = 1; i <= 3; i++) {
                let $el = $(`#indicator-${i}`);
                if (i < currentStep) $el.addClass('completed');
                else if (i === currentStep) {
                    if (i === 3) $el.addClass('completed');
                    else $el.addClass('active');
                }
            }
        }
    </script>
}