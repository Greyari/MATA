@{
    ViewData["Title"] = "Cable Borrow Wizard";
}

<style>
    /* --- STEPPER STYLE (Sama dengan halaman Return) --- */
    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 40px;
        position: relative;
        padding: 0 50px;
    }

    .stepper-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }

        .stepper-item::before {
            content: '';
            position: absolute;
            top: 20px;
            left: -50%;
            width: 100%;
            height: 2px;
            background-color: #e0e0e0;
            z-index: 1;
        }

        .stepper-item:first-child::before {
            content: none;
        }

    .step-counter {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #6c757d;
        color: #fff;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
        margin-bottom: 6px;
        transition: all 0.3s ease;
        position: relative;
        z-index: 5;
    }

    .step-name {
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 500;
    }

    /* Active State */
    .stepper-item.active .step-counter {
        background-color: #dbeafe;
        color: #1e40af;
        border: 2px solid #1e40af;
    }

    .stepper-item.active .step-name {
        color: #1e40af;
        font-weight: bold;
    }

    /* Completed State */
    .stepper-item.completed .step-counter {
        background-color: #d1fae5;
        color: #065f46;
    }

    .stepper-item.completed::before {
        background-color: #10b981;
    }

    .stepper-item.completed .step-name {
        color: #065f46;
    }

    /* --- FORM CARD STYLING --- */
    .wizard-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 40px;
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
        min-height: 350px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .scanner-input {
        font-size: 1.5rem;
        text-align: center;
        letter-spacing: 2px;
        border: 2px solid #ddd;
        border-radius: 8px;
        padding: 15px;
        width: 100%;
        margin-top: 20px;
        transition: border-color 0.3s;
    }

        .scanner-input:focus {
            border-color: #3dcd58; /* Schneider Green */
            outline: none;
            box-shadow: 0 0 0 4px rgba(61, 205, 88, 0.1);
        }

    .helper-text {
        color: #888;
        font-size: 0.9rem;
        margin-top: 10px;
        font-style: italic;
    }

    .hidden-step {
        display: none;
    }

    .scan-icon-anim {
        font-size: 4rem;
        color: #007bff; /* Blue for Borrowing */
        margin-bottom: 20px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.7;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<div class="container pt-5 pb-5">

    <div class="stepper-wrapper">
        <div class="stepper-item active" id="indicator-1">
            <div class="step-counter">1</div>
            <div class="step-name">Scan Location</div>
        </div>
        <div class="stepper-item" id="indicator-2">
            <div class="step-counter">2</div>
            <div class="step-name">Scan Cable</div>
        </div>
        <div class="stepper-item" id="indicator-3">
            <div class="step-counter">3</div>
            <div class="step-name">Finish</div>
        </div>
    </div>

    <div class="wizard-card">

        <div id="step-1-content">
            <i class="fas fa-map-marker-alt scan-icon-anim"></i>
            <h3>Step 1: Scan Source Location</h3>
            <p class="text-muted">Scan the QR code of the Location where you are taking the cable from.</p>

            <input type="text" id="inputLocation" class="scanner-input" placeholder="Scan Location Code..." autofocus autocomplete="off">
            <p class="helper-text"><i class="fas fa-keyboard"></i> Waiting for scanner input...</p>
        </div>

        <div id="step-2-content" class="hidden-step">
            <i class="fas fa-barcode scan-icon-anim text-success"></i>
            <h3>Step 2: Scan Cable QR</h3>
            <p class="text-muted">Now, scan the QR code on the cable you are borrowing.</p>

            <div class="alert alert-primary py-2 mb-4" style="font-size: 0.9rem;">
                <strong>Taking from:</strong> <span id="displayLocation">---</span>
            </div>

            <input type="text" id="inputCable" class="scanner-input" placeholder="Scan Cable ID..." autocomplete="off">
            <p class="helper-text"><i class="fas fa-keyboard"></i> Waiting for scanner input...</p>

            <button class="btn btn-secondary btn-sm mt-3" onclick="prevStep(1)">Back</button>
        </div>

        <div id="step-3-content" class="hidden-step">
            <div class="text-center">
                <i class="fas fa-clipboard-check text-primary" style="font-size: 5rem; margin-bottom: 20px;"></i>
                <h2 class="text-primary">Borrow Success!</h2>
                <p>The cable has been recorded as borrowed.</p>

                <div class="card bg-light border-0 p-3 mt-3 mb-4 text-left d-inline-block" style="min-width: 300px;">
                    <div><strong>Source Location:</strong> <span id="summaryLoc"></span></div>
                    <div><strong>Cable ID:</strong> <span id="summaryCable"></span></div>
                    <div><strong>Time:</strong> <span id="summaryTime"></span></div>
                </div>

                <div>
                    <button class="btn btn-outline-primary" onclick="resetProcess()">Borrow Another Cable</button>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Variabel untuk menyimpan QR Code Lokasi sementara
        var currentLocationQR = "";

        $(document).ready(function() {
            // Fokus otomatis ke input pertama
            $('#inputLocation').focus();

            // --- LOGIKA STEP 1: SCAN LOCATION ---
            $('#inputLocation').on('keypress', function(e) {
                if(e.which == 13) {
                    var locCode = $(this).val().trim();

                    if(locCode !== "") {
                        // Tampilkan loading (opsional, UX lebih baik)
                        Swal.fire({title: 'Checking...', allowOutsideClick: false, didOpen: () => Swal.showLoading()});

                        // AJAX Call ke CheckLocation
                        $.ajax({
                            url: "@Url.Action("CheckLocation")",
                            type: 'GET',
                            data: { qr_code: locCode },
                            success: function(response) {
                                Swal.close(); // Tutup loading

                                if (response.success) {
                                    // Simpan QR Code untuk validasi Step 2
                                    currentLocationQR = locCode;

                                    // Tampilkan data lokasi di UI Step 2
                                    $('#displayLocation').text(response.line + " - " + response.location);
                                    $('#summaryLoc').text(response.line + " - " + response.location);

                                    // Pindah ke Step 2
                                    goToStep(2);
                                } else {
                                    // Jika Drawer tidak ditemukan
                                    Swal.fire({
                                        icon: "error",
                                        title: "Not Found",
                                        text: response.message,
                                        timer: 2000
                                    });
                                    $('#inputLocation').val(''); // Clear input
                                }
                            },
                            error: function() {
                                Swal.fire({
                                    icon: "error",
                                    title: "Error",
                                    text: "Server connection failed",
                                    timer: 2000
                                });
                            }
                        });

                    } else {
                        // Jika input kosong
                        Swal.fire({ 
                            icon: "warning", 
                            title: "Oops...", 
                            text: "Please scan a valid location code!", 
                            timer: 2000 
                        });
                    }
                }
            });

            // --- LOGIKA STEP 2: SCAN CABLE ---
            $('#inputCable').on('keypress', function(e) {
                if(e.which == 13) {
                    var cableCode = $(this).val().trim();

                    if(cableCode !== "") {
                        Swal.fire({title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading()});

                        // AJAX Call ke ProcessBorrow
                        $.ajax({
                            url: "@Url.Action("ProcessBorrow")",
                            type: 'POST',
                            data: {
                                cable_qr: cableCode,
                                drawer_qr: currentLocationQR
                            },
                            success: function(response) {
                                Swal.close();

                                if (response.success) {
                                    // SUKSES
                                    
                                    // --- PERUBAHAN DISINI ---
                                    // Gunakan 'response.realCableId' dari Controller
                                    $('#summaryCable').text(response.realCableId); 
                                    // ------------------------

                                    $('#summaryTime').text(new Date().toLocaleString());

                                    goToStep(3); // Pindah ke Finish
                                } else {
                                    // GAGAL
                                    Swal.fire({
                                        icon: "error",
                                        title: "Validation Failed",
                                        text: response.message,
                                        timer: 2000
                                    });
                                    $('#inputCable').val(''); 
                                }
                            },
                            error: function() {
                                // Swal.fire("Error", "Server connection failed", "error");
                                Swal.fire({
                                    icon: "error",
                                    title: "Error",
                                    text: "Server connection failed",
                                    timer: 2000
                                });
                            }
                        });

                    } else {
                        Swal.fire({ 
                            icon: "warning", 
                            title: "Oops...", 
                            text: "Please scan a valid cable code!", 
                            timer: 2000 
                        });
                    }
                }
            });
        });

        // --- FUNGSI NAVIGASI STEPPER (Tidak Berubah) ---
        function goToStep(stepNumber) {
            $('#step-1-content, #step-2-content, #step-3-content').hide();
            $(`#step-${stepNumber}-content`).fadeIn();
            updateStepperVisuals(stepNumber);

            if(stepNumber === 1) {
                setTimeout(() => $('#inputLocation').val('').focus(), 100);
            } else if (stepNumber === 2) {
                setTimeout(() => $('#inputCable').val('').focus(), 100);
            }
        }

        function prevStep(stepNumber) {
            goToStep(stepNumber);
        }

        function resetProcess() {
            $('#inputLocation').val('');
            $('#inputCable').val('');
            $('#displayLocation').text('---');
            currentLocationQR = ""; // Reset variabel global
            goToStep(1);
        }

        function updateStepperVisuals(currentStep) {
            $('.stepper-item').removeClass('active completed');
            for (let i = 1; i <= 3; i++) {
                let $el = $(`#indicator-${i}`);
                if (i < currentStep) {
                    $el.addClass('completed');
                } else if (i === currentStep) {
                    if (i === 3) {
                        $el.addClass('completed');
                    } else {
                        $el.addClass('active');
                    }
                }
            }
        }
    </script>
}